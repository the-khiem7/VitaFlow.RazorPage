@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <div class="hero-section bg-danger text-white py-5 mb-5 rounded">
        <div class="container">
            <h1 class="display-4">
                <i class="fas fa-heart"></i> Blood Donation Management System
            </h1>
            <p class="lead">Save lives by donating blood. Every donation counts and makes a difference.</p>
            <div class="hero-stats row mt-4 mb-4">
                <div class="col-md-4">
                    <div class="stat-item">
                        <h3 class="stat-number" data-target="1250">0</h3>
                        <p class="stat-label">Lives Saved</p>
                    </div>

@section Scripts {
    <script>
        // Counter Animation
        function animateCounters() {
            const counters = document.querySelectorAll('.stat-number');
            counters.forEach(counter => {
                const target = parseInt(counter.getAttribute('data-target'));
                const increment = target / 100;
                let current = 0;
                
                const timer = setInterval(() => {
                    current += increment;
                    if (current >= target) {
                        counter.textContent = target;
                        clearInterval(timer);
                    } else {
                        counter.textContent = Math.floor(current);
                    }
                }, 20);
            });
        }
        
        // Scroll Animation
        function handleScrollAnimations() {
            const elements = document.querySelectorAll('.fade-in');
            elements.forEach(element => {
                const elementTop = element.getBoundingClientRect().top;
                const elementVisible = 150;
                
                if (elementTop < window.innerHeight - elementVisible) {
                    const delay = element.getAttribute('data-delay') || 0;
                    setTimeout(() => {
                        element.classList.add('visible');
                    }, delay);
                }
            });
        }
        
        // Blood Type Card Interactions
        function initBloodTypeCards() {
            const cards = document.querySelectorAll('.blood-type-card');
            cards.forEach(card => {
                card.addEventListener('click', function() {
                    const bloodType = this.getAttribute('data-type');
                    // Add click effect
                    this.style.transform = 'scale(0.95)';
                    setTimeout(() => {
                        this.style.transform = 'scale(1)';
                    }, 150);
                    
                    // Show compatibility info (you can expand this)
                    console.log('Blood type selected:', bloodType);
                });
            });
        }
        
        // Initialize everything when page loads
        document.addEventListener('DOMContentLoaded', function() {
            // Start counter animation after a short delay
            setTimeout(animateCounters, 1000);
            
            // Initialize scroll animations
            handleScrollAnimations();
            window.addEventListener('scroll', handleScrollAnimations);
            
            // Initialize blood type cards
            initBloodTypeCards();
            
            // Add pulse effect to CTA buttons
            const pulseButtons = document.querySelectorAll('.pulse-btn');
            pulseButtons.forEach(btn => {
                setInterval(() => {
                    btn.style.transform = 'scale(1.05)';
                    setTimeout(() => {
                        btn.style.transform = 'scale(1)';
                    }, 200);
                }, 3000);
            });
        });
    </script>
}
                </div>
                <div class="col-md-4">
                    <div class="stat-item">
                        <h3 class="stat-number" data-target="850">0</h3>
                        <p class="stat-label">Active Donors</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-item">
                        <h3 class="stat-number" data-target="95">0</h3>
                        <p class="stat-label">Success Rate %</p>
                    </div>
                </div>
            </div>
            @if (User.Identity?.IsAuthenticated != true)
            {
                <a class="btn btn-light btn-lg pulse-btn" asp-page="/Account/Register" role="button">
                    <i class="fas fa-user-plus"></i> Join Us Today
                </a>
            }
        </div>
    </div>
</div>

<div class="container">
    <!-- Quick Actions Section -->
    <div class="row fade-in" data-delay="100">
        <div class="col-md-4 mb-4">
            <div class="card h-100 action-card">
                <div class="card-body text-center">
                    <div class="icon-wrapper mb-3">
                        <i class="fas fa-tint fa-3x text-danger"></i>
                    </div>
                    <h5 class="card-title">Donate Blood</h5>
                    <p class="card-text">Schedule your blood donation appointment and help save lives in your community.</p>
                    <div class="card-footer-custom">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a href="/Donation/Register" class="btn btn-danger btn-action">
                                <i class="fas fa-calendar-plus"></i> Register Donation
                            </a>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-danger btn-action">
                                <i class="fas fa-sign-in-alt"></i> Login to Donate
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-4">
            <div class="card h-100 action-card">
                <div class="card-body text-center">
                    <div class="icon-wrapper mb-3">
                        <i class="fas fa-search fa-3x text-primary"></i>
                    </div>
                    <h5 class="card-title">Find Blood</h5>
                    <p class="card-text">Search for available blood types and submit requests for blood units.</p>
                    <div class="card-footer-custom">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a href="/BloodRequest/Search" class="btn btn-primary btn-action">
                                <i class="fas fa-search"></i> Search Blood
                            </a>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-primary btn-action">
                                <i class="fas fa-sign-in-alt"></i> Login to Search
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-4">
            <div class="card h-100 action-card">
                <div class="card-body text-center">
                    <div class="icon-wrapper mb-3">
                        <i class="fas fa-certificate fa-3x text-success"></i>
                    </div>
                    <h5 class="card-title">Get Certificate</h5>
                    <p class="card-text">Download your donation certificates and track your contribution history.</p>
                    <div class="card-footer-custom">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a href="/Donation/Certificates" class="btn btn-success btn-action">
                                <i class="fas fa-download"></i> View Certificates
                            </a>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-success btn-action">
                                <i class="fas fa-sign-in-alt"></i> Login to View
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Blood Types Compatibility Section -->
    <div class="row mt-5 fade-in" data-delay="200">
        <div class="col-12">
            <h2 class="text-center mb-4">Blood Type Compatibility</h2>
            <div class="blood-types-grid">
                <div class="blood-type-card" data-type="O-">
                    <div class="blood-type-icon">O-</div>
                    <div class="blood-type-label">Universal Donor</div>
                </div>
                <div class="blood-type-card" data-type="AB+">
                    <div class="blood-type-icon">AB+</div>
                    <div class="blood-type-label">Universal Recipient</div>
                </div>
                <div class="blood-type-card" data-type="A+">
                    <div class="blood-type-icon">A+</div>
                    <div class="blood-type-label">Common Type</div>
                </div>
                <div class="blood-type-card" data-type="B+">
                    <div class="blood-type-icon">B+</div>
                    <div class="blood-type-label">Common Type</div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Why Donate Section -->
    <div class="row mt-5 fade-in" data-delay="300">
        <div class="col-12">
            <h2 class="text-center mb-5">Why Donate Blood?</h2>
        </div>
        <div class="col-md-6">
            <div class="feature-item d-flex mb-4">
                <div class="feature-icon flex-shrink-0">
                    <i class="fas fa-heart text-danger fa-2x"></i>
                </div>
                <div class="feature-content flex-grow-1 ms-3">
                    <h5>Save Lives</h5>
                    <p>One blood donation can save up to three lives. Your contribution makes a real difference in emergency situations and ongoing medical treatments.</p>
                    <div class="feature-stats">
                        <small class="text-muted"><i class="fas fa-info-circle"></i> 1 donation = 3 lives saved</small>
                    </div>
                </div>
            </div>
            
            <div class="feature-item d-flex mb-4">
                <div class="feature-icon flex-shrink-0">
                    <i class="fas fa-users text-primary fa-2x"></i>
                </div>
                <div class="feature-content flex-grow-1 ms-3">
                    <h5>Help Your Community</h5>
                    <p>Support local hospitals and emergency services with a steady blood supply for surgeries, trauma care, and chronic conditions.</p>
                    <div class="feature-stats">
                        <small class="text-muted"><i class="fas fa-hospital"></i> Supporting 15+ local hospitals</small>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="feature-item d-flex mb-4">
                <div class="feature-icon flex-shrink-0">
                    <i class="fas fa-shield-alt text-success fa-2x"></i>
                </div>
                <div class="feature-content flex-grow-1 ms-3">
                    <h5>Safe Process</h5>
                    <p>All donations follow strict safety protocols with sterile equipment, trained medical staff, and comprehensive health screenings.</p>
                    <div class="feature-stats">
                        <small class="text-muted"><i class="fas fa-check-circle"></i> 100% sterile equipment</small>
                    </div>
                </div>
            </div>
            
            <div class="feature-item d-flex mb-4">
                <div class="feature-icon flex-shrink-0">
                    <i class="fas fa-clock text-warning fa-2x"></i>
                </div>
                <div class="feature-content flex-grow-1 ms-3">
                    <h5>Quick & Easy</h5>
                    <p>The entire donation process takes about 30-45 minutes of your time, including registration, health check, and refreshments.</p>
                    <div class="feature-stats">
                        <small class="text-muted"><i class="fas fa-stopwatch"></i> Average time: 35 minutes</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Emergency Blood Needs Section -->
    <div class="row mt-5 fade-in" data-delay="400">
        <div class="col-12">
            <div class="emergency-banner">
                <div class="emergency-content">
                    <h3><i class="fas fa-exclamation-triangle"></i> Current Blood Needs</h3>
                    <p>Help us maintain adequate blood supply for emergency situations</p>
                    <div class="blood-need-indicators">
                        <div class="need-item urgent">
                            <span class="blood-type">O-</span>
                            <span class="need-level">URGENT</span>
                        </div>
                        <div class="need-item high">
                            <span class="blood-type">A+</span>
                            <span class="need-level">HIGH</span>
                        </div>
                        <div class="need-item medium">
                            <span class="blood-type">B+</span>
                            <span class="need-level">MEDIUM</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="row mt-5 fade-in" data-delay="500">
            <div class="col-12">
                <div class="welcome-card">
                    <div class="welcome-header">
                        <div class="welcome-avatar">
                            <i class="fas fa-user-circle fa-3x"></i>
                        </div>
                        <div class="welcome-text">
                            <h4 class="welcome-title">Welcome back, @User.Identity.Name!</h4>
                            <p class="welcome-subtitle">Thank you for being part of our blood donation community</p>
                        </div>
                    </div>
                    <div class="welcome-content">
                        <p>Check your dashboard for upcoming appointments and donation history. Your contributions are making a real difference!</p>
                        <div class="welcome-actions">
                            <a href="/Donation/History" class="btn btn-info btn-welcome">
                                <i class="fas fa-history"></i> View My History
                            </a>
                            <a href="/Donation/Register" class="btn btn-outline-info btn-welcome ms-2">
                                <i class="fas fa-plus"></i> Register New Donation
                            </a>
                            <a href="/Member/Dashboard" class="btn btn-outline-secondary btn-welcome ms-2">
                                <i class="fas fa-tachometer-alt"></i> Dashboard
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row mt-5 fade-in" data-delay="500">
            <div class="col-12">
                <div class="cta-section text-center">
                    <h3>Ready to Save Lives?</h3>
                    <p class="lead">Join thousands of heroes who are making a difference in their community</p>
                    <div class="cta-buttons">
                        <a href="/Account/Register" class="btn btn-danger btn-lg me-3">
                            <i class="fas fa-user-plus"></i> Register Now
                        </a>
                        <a href="/Account/Login" class="btn btn-outline-danger btn-lg">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
