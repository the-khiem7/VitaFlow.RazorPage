@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <div class="hero-section bg-danger text-white py-5 mb-5 rounded">
        <div class="container">
            <h1 class="display-4">
                <i class="fas fa-heart"></i> Blood Donation Management System
            </h1>
            <p class="lead">Save lives by donating blood. Every donation counts and makes a difference.</p>
            @if (User.Identity?.IsAuthenticated != true)
            {
                <a class="btn btn-light btn-lg" asp-page="/Account/Register" role="button">
                    <i class="fas fa-user-plus"></i> Join Us Today
                </a>
            }
        </div>
    </div>
</div>

<div class="container">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-tint fa-3x text-danger mb-3"></i>
                    <h5 class="card-title">Donate Blood</h5>
                    <p class="card-text">Schedule your blood donation appointment and help save lives in your community.</p>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/Donation/Register" class="btn btn-danger">Register Donation</a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-danger">Login to Donate</a>
                    }
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-search fa-3x text-primary mb-3"></i>
                    <h5 class="card-title">Find Blood</h5>
                    <p class="card-text">Search for available blood types and submit requests for blood units.</p>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/BloodRequest/Search" class="btn btn-primary">Search Blood</a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-primary">Login to Search</a>
                    }
                </div>
            </div>
        </div>
        
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-certificate fa-3x text-success mb-3"></i>
                    <h5 class="card-title">Get Certificate</h5>
                    <p class="card-text">Download your donation certificates and track your contribution history.</p>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/Donation/Certificates" class="btn btn-success">View Certificates</a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-success">Login to View</a>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-5">
        <div class="col-12">
            <h2 class="text-center mb-4">Why Donate Blood?</h2>
        </div>
        <div class="col-md-6">
            <div class="d-flex mb-3">
                <div class="flex-shrink-0">
                    <i class="fas fa-heart text-danger fa-2x"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h5>Save Lives</h5>
                    <p>One blood donation can save up to three lives. Your contribution makes a real difference.</p>
                </div>
            </div>
            
            <div class="d-flex mb-3">
                <div class="flex-shrink-0">
                    <i class="fas fa-users text-primary fa-2x"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h5>Help Your Community</h5>
                    <p>Support local hospitals and emergency services with a steady blood supply.</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="d-flex mb-3">
                <div class="flex-shrink-0">
                    <i class="fas fa-shield-alt text-success fa-2x"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h5>Safe Process</h5>
                    <p>All donations follow strict safety protocols with sterile equipment and trained staff.</p>
                </div>
            </div>
            
            <div class="d-flex mb-3">
                <div class="flex-shrink-0">
                    <i class="fas fa-clock text-warning fa-2x"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h5>Quick & Easy</h5>
                    <p>The entire donation process takes about 30-45 minutes of your time.</p>
                </div>
            </div>
        </div>
    </div>
    
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="row mt-5">
            <div class="col-12">
                <div class="alert alert-info">
                    <h4 class="alert-heading">Welcome back, @User.Identity.Name!</h4>
                    <p>Thank you for being part of our blood donation community. Check your dashboard for upcoming appointments and donation history.</p>
                    <hr>
                    <p class="mb-0">
                        <a href="/Donation/History" class="btn btn-info">View My History</a>
                        <a href="/Donation/Register" class="btn btn-outline-info ms-2">Register New Donation</a>
                    </p>
                </div>
            </div>
        </div>
    }
</div>
