<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blood Donation Management System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RazorPage.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-danger border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <i class="fas fa-heart text-white"></i> Blood Donation System
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-page="/Index">
                                <i class="fas fa-home"></i> Home
                            </a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Donation/BloodCompatibility">
                                <i class="fas fa-search"></i> Blood Compatibility
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Donation/LocationSearch">
                                <i class="fas fa-map-marker-alt"></i> Find Nearby Donors
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin") && !User.IsInRole("Staff"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-cog"></i> Admin
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-page="/Admin/Index">Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-page="/Admin/Users">User Management</a></li>
                                        <li><a class="dropdown-item" asp-page="/Admin/BloodManagement">Blood Management</a></li>
                                        <li><a class="dropdown-item" asp-page="/Admin/Reports">Reports</a></li>
                                    </ul>
                                </li>
                            }
                            
                            @if (User.IsInRole("Staff") && !User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-briefcase"></i> Staff
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-page="/Staff/Index">Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-page="/Staff/BloodRequests">Blood Requests</a></li>
                                        <li><a class="dropdown-item" asp-page="/Staff/Donations">Donations</a></li>
                                        <li><a class="dropdown-item" asp-page="/Staff/HealthChecks">Health Checks</a></li>
                                    </ul>
                                </li>
                            }
                            
                            @if (User.IsInRole("Member") || User.IsInRole("Customer"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-user-heart"></i> Member
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-page="/Member/Index">Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-page="/Member/Appointments">Appointments</a></li>
                                        <li><a class="dropdown-item" asp-page="/Member/History">Donation History</a></li>
                                        <li><a class="dropdown-item" asp-page="/Member/Health"><i class="fas fa-heartbeat"></i> Health Status</a></li>
                                        <li><a class="dropdown-item" asp-page="/Member/Certificates"><i class="fas fa-certificate"></i> Certificates</a></li>
                                        <li><a class="dropdown-item" asp-page="/Member/Profile">My Profile</a></li>
                                    </ul>
                                </li>
                            }
                            
                            @if (User.IsInRole("Member") || User.IsInRole("Customer"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-tint"></i> Donation
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-page="/Donation/Register">Register Donation</a></li>
                                        <li><a class="dropdown-item" asp-page="/Member/History">My History</a></li>
                                        <li><a class="dropdown-item" asp-page="/Member/Certificates">Certificates</a></li>
                                        <li><a class="dropdown-item" asp-page="/Donation/BloodCompatibility"><i class="fas fa-search"></i> Blood Type Compatibility</a></li>
                                        <li><a class="dropdown-item" asp-page="/Donation/LocationSearch"><i class="fas fa-map-marker-alt"></i> Find Nearby Donors</a></li>
                                    </ul>
                                </li>
                            }
                            
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-page="/Blog/Index">
                                    <i class="fas fa-blog"></i> Blog
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-page="/Privacy">Privacy</a>
                            </li>
                        }
                    </ul>
                    
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/Member/Profile">Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-page="/Account/Logout">Logout</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-page="/Account/Login">
                                    <i class="fas fa-sign-in-alt"></i> Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-page="/Account/Register">
                                    <i class="fas fa-user-plus"></i> Register
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container-fluid">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light">
        <div class="container">
            <div class="row py-3">
                <div class="col-md-6">
                    &copy; 2024 - Blood Donation Management System
                </div>
                <div class="col-md-6 text-end">
                    <a asp-area="" asp-page="/Privacy">Privacy</a> |
                    <a href="/swagger" target="_blank">API Documentation</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>