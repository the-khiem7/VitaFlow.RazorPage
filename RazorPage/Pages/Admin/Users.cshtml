@page
@model RazorPage.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "User Management";
}

<style>
    /* Modern Admin Theme */
    .admin-container {
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        min-height: 100vh;
        padding: 2rem 0;
    }

    .page-header {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        border-radius: 20px;
        padding: 2.5rem;
        margin-bottom: 2rem;
        text-align: center;
    }

    .header-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        box-shadow: 0 8px 16px rgba(59, 130, 246, 0.2);
    }

    .admin-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        border-radius: 16px;
        overflow: hidden;
    }

    .card-header-modern {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        padding: 1.5rem;
        border: none;
        color: white;
    }

    .search-input {
        background: #ffffff;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        transition: all 0.3s ease;
        padding: 12px;
    }

        .search-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
            background: #ffffff;
        }

    .btn-modern {
        border-radius: 10px;
        padding: 12px 20px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
    }

        .btn-modern:hover {
            transform: translateY(-2px);
        }

    .btn-primary-modern {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        color: white;
    }

        .btn-primary-modern:hover {
            box-shadow: 0 8px 16px rgba(59, 130, 246, 0.25);
            color: white;
        }

    .btn-outline-modern {
        background: #ffffff;
        border: 1.5px solid #e2e8f0;
        color: #374151;
    }

        .btn-outline-modern:hover {
            background: #f9fafb;
            border-color: #d1d5db;
            color: #374151;
        }

    .table-modern {
        border: none;
    }

        .table-modern thead th {
            background: #f8fafc;
            border: none;
            font-weight: 600;
            color: #374151;
            padding: 1rem;
        }

        .table-modern tbody td {
            border: none;
            padding: 1rem;
            vertical-align: middle;
        }

        .table-modern tbody tr {
            border-bottom: 1px solid #f1f5f9;
        }

            .table-modern tbody tr:hover {
                background: #f8fafc;
            }

    .modal-modern .modal-content {
        border: none;
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .modal-modern .modal-header {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        color: white;
        border: none;
        border-radius: 16px 16px 0 0;
    }

    .form-control-modern {
        background: #ffffff;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        transition: all 0.3s ease;
        padding: 12px;
    }

        .form-control-modern:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
            background: #ffffff;
        }

    .subtle-pattern {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0.03;
        background-image: radial-gradient(circle at 20% 20%, #3b82f6 1px, transparent 1px);
        background-size: 30px 30px;
    }
</style>

<div class="admin-container position-relative">
    <div class="subtle-pattern"></div>
    <div class="container-fluid position-relative">
        <!-- Page Header -->
        <div class="page-header">
            <div class="header-icon">
                <i class="fas fa-users text-white" style="font-size: 2rem;"></i>
            </div>
            <h1 class="fw-bold text-dark mb-2" style="font-size: 2.8rem;">User Management</h1>
            <p class="text-muted mb-0" style="font-size: 1.2rem;">Manage system users, roles and permissions</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
                @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
                @Model.SuccessMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="admin-card">
            <div class="card-header-modern d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">
                    <i class="fas fa-users me-2"></i>User List
                </h5>
                <div class="d-flex gap-2">
                    <form method="get" class="d-flex">
                        <div class="input-group">
                            <input type="text" class="form-control search-input" name="searchTerm" placeholder="Search users...">
                            <button class="btn btn-outline-modern" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </form>
                    <button type="button" class="btn btn-primary-modern btn-modern" data-bs-toggle="modal" data-bs-target="#addUserModal">
                        <i class="fas fa-plus me-1"></i>Add User
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-modern" id="usersTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Full Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                <tr>
                                    <td>@user.UserId</td>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td>@user.Role</td>
                                    <td>
                                        <span class="badge bg-@(user.Status == "Active" ? "success" : "danger")">@user.Status</span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-primary-modern" onclick="editUser('@user.UserId', '@user.FullName', '@user.Email', '@user.Role', '@user.Status')" data-bs-toggle="modal" data-bs-target="#editUserModal">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add User Modal -->
<div class="modal fade modal-modern" id="addUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form method="post" asp-page-handler="Create">
                    <div class="mb-3">
                        <label asp-for="NewUser.FullName" class="form-label">Full Name</label>
                        <input asp-for="NewUser.FullName" class="form-control form-control-modern" required>
                        <span asp-validation-for="NewUser.FullName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewUser.Email" class="form-label">Email</label>
                        <input asp-for="NewUser.Email" class="form-control form-control-modern" required>
                        <span asp-validation-for="NewUser.Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewUser.Password" class="form-label">Password</label>
                        <input asp-for="NewUser.Password" class="form-control form-control-modern" type="password" required>
                        <span asp-validation-for="NewUser.Password" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewUser.Role" class="form-label">Role</label>
                        <select asp-for="NewUser.Role" class="form-select form-control-modern" required>
                            <option value="Member">Member</option>
                            <option value="Staff">Staff</option>
                            <option value="Admin">Admin</option>
                        </select>
                        <span asp-validation-for="NewUser.Role" class="text-danger"></span>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-modern" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary-modern btn-modern">Save User</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade modal-modern" id="editUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form method="post" asp-page-handler="Update">
                    <input type="hidden" asp-for="UpdateUser.Id">
                    <div class="mb-3">
                        <label asp-for="UpdateUser.FullName" class="form-label">Full Name</label>
                        <input asp-for="UpdateUser.FullName" class="form-control form-control-modern" required>
                        <span asp-validation-for="UpdateUser.FullName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateUser.Email" class="form-label">Email</label>
                        <input asp-for="UpdateUser.Email" class="form-control form-control-modern" required>
                        <span asp-validation-for="UpdateUser.Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateUser.Role" class="form-label">Role</label>
                        <select asp-for="UpdateUser.Role" class="form-select form-control-modern" required>
                            <option value="Member">Member</option>
                            <option value="Staff">Staff</option>
                            <option value="Admin">Admin</option>
                        </select>
                        <span asp-validation-for="UpdateUser.Role" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateUser.Status" class="form-label">Status</label>
                        <select asp-for="UpdateUser.Status" class="form-select form-control-modern" required>
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                        <span asp-validation-for="UpdateUser.Status" class="text-danger"></span>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-modern" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary-modern btn-modern">Update User</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function editUser(id, fullName, email, role, status) {
            document.getElementById('UpdateUser_Id').value = id;
            document.getElementById('UpdateUser_FullName').value = fullName;
            document.getElementById('UpdateUser_Email').value = email;
            document.getElementById('UpdateUser_Role').value = role;
            document.getElementById('UpdateUser_Status').value = status;
        }
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}