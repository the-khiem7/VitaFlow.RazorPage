@page
@model RazorPage.Pages.Member.IndexModel
@{
    ViewData["Title"] = "Member Dashboard";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h1 class="display-4">Member Dashboard</h1>
            <p class="lead">Welcome to your Blood Donation Portal</p>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3">
                <div class="card-header">
                    <i class="fas fa-calendar-plus"></i> Schedule Donation
                </div>
                <div class="card-body">
                    <h5 class="card-title">Book Appointment</h5>
                    <p class="card-text">Schedule your next blood donation appointment</p>
                    <a href="/Member/Appointments" class="btn btn-light">Schedule Now</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card text-white bg-info mb-3">
                <div class="card-header">
                    <i class="fas fa-history"></i> Donation History
                </div>
                <div class="card-body">
                    <h5 class="card-title">My Donations</h5>
                    <p class="card-text">View your donation history and records</p>
                    <a href="/Member/History" class="btn btn-light">View History</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card text-white bg-warning mb-3">
                <div class="card-header">
                    <i class="fas fa-certificate"></i> Certificates
                </div>
                <div class="card-body">
                    <h5 class="card-title">My Certificates</h5>
                    <p class="card-text">Download your donation certificates</p>
                    <a href="/Member/Certificates" class="btn btn-light">View Certificates</a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3">
                <div class="card-header">
                    <i class="fas fa-user-edit"></i> Profile Management
                </div>
                <div class="card-body">
                    <h5 class="card-title">Update Profile</h5>
                    <p class="card-text">Manage your personal information and preferences</p>
                    <a href="/Member/Profile" class="btn btn-light">Edit Profile</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card text-white bg-secondary mb-3">
                <div class="card-header">
                    <i class="fas fa-heartbeat"></i> Health Status
                </div>
                <div class="card-body">
                    <h5 class="card-title">Health Records</h5>
                    <p class="card-text">View your health check results and eligibility</p>
                    <a href="/Member/Health" class="btn btn-light">View Health Status</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card text-white bg-info mb-3">
                <div class="card-header">
                    <i class="fas fa-newspaper"></i> Blog Posts
                </div>
                <div class="card-body">
                    <h5 class="card-title">Latest Articles</h5>
                    <p class="card-text">Stay informed with news and articles about blood donation</p>
                    <a href="/Member/BlogPosts" class="btn btn-light">Read Articles</a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-bell"></i> Recent Notifications</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info" role="alert">
                        <i class="fas fa-info-circle"></i> Your next eligible donation date is in 2 weeks.
                    </div>
                    <div class="alert alert-success" role="alert">
                        <i class="fas fa-check-circle"></i> Thank you for your last donation! You've helped save lives.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>