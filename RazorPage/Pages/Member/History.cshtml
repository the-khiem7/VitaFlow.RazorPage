@page
@model RazorPage.Pages.Member.HistoryModel
@{
    ViewData["Title"] = "Donation History";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h1 class="display-5">My Donation History</h1>
            <p class="lead">Track your blood donation journey and impact</p>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-md-3">
            <div class="card text-white bg-success mb-3">
                <div class="card-body text-center">
                    <h2 class="card-title">12</h2>
                    <p class="card-text">Total Donations</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card text-white bg-info mb-3">
                <div class="card-body text-center">
                    <h2 class="card-title">36</h2>
                    <p class="card-text">Lives Potentially Saved</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card text-white bg-warning mb-3">
                <div class="card-body text-center">
                    <h2 class="card-title">6L</h2>
                    <p class="card-text">Total Blood Donated</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card text-white bg-danger mb-3">
                <div class="card-body text-center">
                    <h2 class="card-title">Jan 28</h2>
                    <p class="card-text">Next Eligible Date</p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5><i class="fas fa-history"></i> Donation Records</h5>
                    <div>
                        <button class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-download"></i> Export PDF
                        </button>
                        <button class="btn btn-outline-success btn-sm">
                            <i class="fas fa-file-excel"></i> Export Excel
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Date</th>
                                    <th>Location</th>
                                    <th>Blood Type</th>
                                    <th>Volume (ml)</th>
                                    <th>Staff</th>
                                    <th>Status</th>
                                    <th>Certificate</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>2023-12-15</td>
                                    <td>Main Blood Center</td>
                                    <td><span class="badge bg-danger">O+</span></td>
                                    <td>500ml</td>
                                    <td>Dr. Smith</td>
                                    <td><span class="badge bg-success">Completed</span></td>
                                    <td>
                                        <a href="#" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-download"></i> Download
                                        </a>
                                    </td>
                                </tr>
                                <tr>
                                    <td>2023-10-20</td>
                                    <td>North Branch</td>
                                    <td><span class="badge bg-danger">O+</span></td>
                                    <td>500ml</td>
                                    <td>Nurse Johnson</td>
                                    <td><span class="badge bg-success">Completed</span></td>
                                    <td>
                                        <a href="#" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-download"></i> Download
                                        </a>
                                    </td>
                                </tr>
                                <tr>
                                    <td>2023-08-25</td>
                                    <td>Mobile Unit</td>
                                    <td><span class="badge bg-danger">O+</span></td>
                                    <td>500ml</td>
                                    <td>Dr. Wilson</td>
                                    <td><span class="badge bg-success">Completed</span></td>
                                    <td>
                                        <a href="#" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-download"></i> Download
                                        </a>
                                    </td>
                                </tr>
                                <tr>
                                    <td>2023-06-30</td>
                                    <td>Main Blood Center</td>
                                    <td><span class="badge bg-danger">O+</span></td>
                                    <td>500ml</td>
                                    <td>Nurse Davis</td>
                                    <td><span class="badge bg-warning">Under Review</span></td>
                                    <td>
                                        <span class="text-muted">Pending</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    
                    <nav aria-label="Donation history pagination">
                        <ul class="pagination justify-content-center">
                            <li class="page-item disabled">
                                <a class="page-link" href="#" tabindex="-1">Previous</a>
                            </li>
                            <li class="page-item active">
                                <a class="page-link" href="#">1</a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" href="#">2</a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" href="#">3</a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" href="#">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h6><i class="fas fa-chart-line"></i> Donation Timeline</h6>
                </div>
                <div class="card-body">
                    <canvas id="donationChart" width="400" height="200"></canvas>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h6><i class="fas fa-trophy"></i> Achievements</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6 text-center mb-3">
                            <i class="fas fa-medal fa-2x text-warning"></i>
                            <p class="small mt-1">First Donation</p>
                        </div>
                        <div class="col-6 text-center mb-3">
                            <i class="fas fa-star fa-2x text-success"></i>
                            <p class="small mt-1">5 Donations</p>
                        </div>
                        <div class="col-6 text-center mb-3">
                            <i class="fas fa-crown fa-2x text-warning"></i>
                            <p class="small mt-1">10 Donations</p>
                        </div>
                        <div class="col-6 text-center mb-3">
                            <i class="fas fa-gem fa-2x text-info"></i>
                            <p class="small mt-1">Life Saver</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Simple donation timeline chart
        const ctx = document.getElementById('donationChart').getContext('2d');
        const donationChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                datasets: [{
                    label: 'Donations',
                    data: [1, 0, 1, 0, 1, 1, 0, 1, 0, 1, 0, 1],
                    borderColor: 'rgb(220, 53, 69)',
                    backgroundColor: 'rgba(220, 53, 69, 0.1)',
                    tension: 0.1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 2
                    }
                }
            }
        });
    </script>
}