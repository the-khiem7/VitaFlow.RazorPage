@page
@model RazorPage.Pages.Member.BlogPostsModel
@{
    ViewData["Title"] = "Blog Posts";
}

<style>
    .blog-hero {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        padding: 4rem 0;
        margin-bottom: 3rem;
        position: relative;
        overflow: hidden;
    }

    .blog-hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="white" opacity="0.1"/><circle cx="75" cy="75" r="1" fill="white" opacity="0.1"/><circle cx="50" cy="10" r="0.5" fill="white" opacity="0.1"/><circle cx="10" cy="60" r="0.5" fill="white" opacity="0.1"/><circle cx="90" cy="40" r="0.5" fill="white" opacity="0.1"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
        opacity: 0.3;
    }

    .blog-hero-content {
        position: relative;
        z-index: 2;
    }

    .blog-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        overflow: hidden;
        background: white;
        margin-bottom: 2rem;
    }

    .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }

    .blog-card-header {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        border: none;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
    }

    .blog-card-header::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain2" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="white" opacity="0.1"/><circle cx="75" cy="75" r="1" fill="white" opacity="0.1"/></pattern></defs><rect width="100" height="100" fill="url(%23grain2)"/></svg>');
        opacity: 0.2;
    }

    .blog-card-title {
        position: relative;
        z-index: 2;
        font-weight: 600;
        margin: 0;
        font-size: 1.25rem;
    }

    .blog-card-category {
        position: relative;
        z-index: 2;
        background: rgba(255,255,255,0.2);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 20px;
        padding: 0.25rem 0.75rem;
        font-size: 0.8rem;
        font-weight: 500;
    }

    .blog-card-body {
        padding: 1.5rem;
        background: white;
    }

    .blog-card-text {
        color: #6c757d;
        line-height: 1.6;
        font-size: 0.95rem;
    }

    .blog-card-footer {
        background: #f8f9fa;
        border: none;
        padding: 1rem 1.5rem;
        border-top: 1px solid #e9ecef;
    }

    .blog-date {
        color: #6c757d;
        font-size: 0.85rem;
        font-weight: 500;
    }

    .read-more-btn {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        border: none;
        border-radius: 25px;
        padding: 0.5rem 1.5rem;
        color: white;
        font-weight: 500;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .read-more-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(220, 53, 69, 0.4);
        color: white;
    }

    .blog-modal .modal-content {
        border-radius: 15px;
        border: none;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    }

    .blog-modal .modal-header {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        border-radius: 15px 15px 0 0;
        border: none;
    }

    .blog-modal .modal-title {
        font-weight: 600;
    }

    .blog-modal .modal-body {
        padding: 2rem;
        line-height: 1.8;
        color: #495057;
    }

    .blog-content {
        font-size: 1rem;
        line-height: 1.8;
    }

    .pagination .page-link {
        border: none;
        color: #dc3545;
        margin: 0 0.25rem;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .pagination .page-link:hover {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        transform: translateY(-2px);
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        border: none;
        color: white;
    }

    .pagination .page-item.disabled .page-link {
        color: #6c757d;
        background: #f8f9fa;
    }

    .no-posts {
        text-align: center;
        padding: 3rem;
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .no-posts-icon {
        font-size: 4rem;
        color: #dc3545;
        margin-bottom: 1rem;
    }

    .stats-section {
        background: #f8f9fa;
        padding: 2rem 0;
        margin-bottom: 3rem;
        border-radius: 15px;
    }

    .stat-item {
        text-align: center;
        padding: 1rem;
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 700;
        color: #dc3545;
        display: block;
    }

    .stat-label {
        color: #6c757d;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .fade-in {
        animation: fadeIn 0.6s ease-in;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .stagger-animation {
        animation: fadeIn 0.6s ease-in;
        animation-fill-mode: both;
    }

    .stagger-animation:nth-child(1) { animation-delay: 0.1s; }
    .stagger-animation:nth-child(2) { animation-delay: 0.2s; }
    .stagger-animation:nth-child(3) { animation-delay: 0.3s; }
    .stagger-animation:nth-child(4) { animation-delay: 0.4s; }
    .stagger-animation:nth-child(5) { animation-delay: 0.5s; }
</style>

<!-- Hero Section -->
<div class="blog-hero">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center blog-hero-content">
                <h1 class="display-4 fw-bold mb-3">
                    <i class="fas fa-newspaper me-3"></i>
                    Blood Donation Blog
                </h1>
                <p class="lead mb-0">
                    Stay informed with the latest news, tips, and stories about blood donation. 
                    Discover how your contribution makes a difference in saving lives.
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Stats Section -->
<div class="container">
    <div class="stats-section">
        <div class="row">
            <div class="col-md-3 stat-item">
                <span class="stat-number">@(Model.Blogs?.Count() ?? 0)</span>
                <span class="stat-label">Articles</span>
            </div>
            <div class="col-md-3 stat-item">
                <span class="stat-number">3</span>
                <span class="stat-label">Categories</span>
            </div>
            <div class="col-md-3 stat-item">
                <span class="stat-number">2024</span>
                <span class="stat-label">Latest Update</span>
            </div>
            <div class="col-md-3 stat-item">
                <span class="stat-number">24/7</span>
                <span class="stat-label">Available</span>
            </div>
        </div>
    </div>
</div>

<!-- Blog Posts Section -->
<div class="container">
    <div class="row">
        <div class="col-12">
            @if (Model.Blogs != null && Model.Blogs.Any())
            {
                <div class="row">
                    @foreach (var blog in Model.Blogs)
                    {
                        <div class="col-lg-6 col-xl-4 mb-4 stagger-animation">
                            <div class="blog-card h-100">
                                <div class="blog-card-header">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h5 class="blog-card-title">@blog.Title</h5>
                                        <span class="blog-card-category">@blog.Category</span>
                                    </div>
                                </div>
                                <div class="blog-card-body">
                                    <p class="blog-card-text">
                                        @if (blog.Content.Length > 200)
                                        {
                                            @(blog.Content.Substring(0, 200) + "...")
                                        }
                                        else
                                        {
                                            @blog.Content
                                        }
                                    </p>
                                </div>
                                <div class="blog-card-footer d-flex justify-content-between align-items-center">
                                    <small class="blog-date">
                                        <i class="fas fa-calendar-alt me-1"></i>
                                        @(blog.PublishDate.HasValue ? blog.PublishDate.Value.ToString("MMM dd, yyyy") : "N/A")
                                    </small>
                                    <button class="read-more-btn" data-bs-toggle="modal" data-bs-target="#blogModal-@blog.BlogId">
                                        <i class="fas fa-arrow-right me-1"></i>
                                        Read More
                                    </button>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Modal for full blog post -->
                        <div class="modal fade blog-modal" id="blogModal-@blog.BlogId" tabindex="-1" aria-labelledby="blogModalLabel-@blog.BlogId" aria-hidden="true">
                            <div class="modal-dialog modal-lg">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="blogModalLabel-@blog.BlogId">
                                            <i class="fas fa-newspaper me-2"></i>
                                            @blog.Title
                                        </h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="d-flex justify-content-between align-items-center mb-4">
                                            <span class="blog-card-category">@blog.Category</span>
                                            <small class="blog-date">
                                                <i class="fas fa-calendar-alt me-1"></i>
                                                @(blog.PublishDate.HasValue ? blog.PublishDate.Value.ToString("MMMM dd, yyyy") : "N/A")
                                            </small>
                                        </div>
                                        <div class="blog-content">
                                            @blog.Content
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                            <i class="fas fa-times me-1"></i>
                                            Close
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                
                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Blog posts pagination" class="mt-5">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-page="./BlogPosts" asp-route-currentPage="@(Model.CurrentPage - 1)" tabindex="-1">
                                    <i class="fas fa-chevron-left me-1"></i>
                                    Previous
                                </a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-page="./BlogPosts" asp-route-currentPage="@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-page="./BlogPosts" asp-route-currentPage="@(Model.CurrentPage + 1)">
                                    Next
                                    <i class="fas fa-chevron-right ms-1"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="no-posts">
                    <div class="no-posts-icon">
                        <i class="fas fa-newspaper"></i>
                    </div>
                    <h3 class="mb-3">No Blog Posts Available</h3>
                    <p class="text-muted mb-0">
                        We're working on creating amazing content for you. Please check back soon!
                    </p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add smooth scrolling and enhanced interactions
        document.addEventListener('DOMContentLoaded', function() {
            // Add fade-in animation to cards
            const cards = document.querySelectorAll('.blog-card');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            });

            cards.forEach(card => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                card.style.transition = 'all 0.6s ease';
                observer.observe(card);
            });

            // Enhanced modal interactions
            const modals = document.querySelectorAll('.blog-modal');
            modals.forEach(modal => {
                modal.addEventListener('show.bs.modal', function() {
                    this.querySelector('.modal-content').style.transform = 'scale(0.8)';
                    this.querySelector('.modal-content').style.opacity = '0';
                });

                modal.addEventListener('shown.bs.modal', function() {
                    this.querySelector('.modal-content').style.transform = 'scale(1)';
                    this.querySelector('.modal-content').style.opacity = '1';
                    this.querySelector('.modal-content').style.transition = 'all 0.3s ease';
                });
            });
        });
    </script>
}