@page
@model RazorPage.Pages.Member.CertificatesModel
@{
    ViewData["Title"] = "My Certificates";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h1 class="display-5">My Certificates</h1>
            <p class="lead">Download and manage your blood donation certificates</p>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-certificate"></i> Available Certificates</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Certificate Type</th>
                                    <th>Donation Date</th>
                                    <th>Issue Date</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <i class="fas fa-award text-warning"></i>
                                        Blood Donation Certificate
                                    </td>
                                    <td>2023-12-15</td>
                                    <td>2023-12-16</td>
                                    <td><span class="badge bg-success">Ready</span></td>
                                    <td>
                                        <a href="#" class="btn btn-sm btn-primary">
                                            <i class="fas fa-download"></i> Download PDF
                                        </a>
                                        <a href="#" class="btn btn-sm btn-outline-secondary">
                                            <i class="fas fa-eye"></i> Preview
                                        </a>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <i class="fas fa-medal text-success"></i>
                                        10 Donations Achievement
                                    </td>
                                    <td>2023-10-20</td>
                                    <td>2023-10-21</td>
                                    <td><span class="badge bg-success">Ready</span></td>
                                    <td>
                                        <a href="#" class="btn btn-sm btn-primary">
                                            <i class="fas fa-download"></i> Download PDF
                                        </a>
                                        <a href="#" class="btn btn-sm btn-outline-secondary">
                                            <i class="fas fa-eye"></i> Preview
                                        </a>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <i class="fas fa-heart text-danger"></i>
                                        Life Saver Certificate
                                    </td>
                                    <td>2023-08-25</td>
                                    <td>2023-08-26</td>
                                    <td><span class="badge bg-warning">Processing</span></td>
                                    <td>
                                        <button class="btn btn-sm btn-secondary" disabled>
                                            <i class="fas fa-clock"></i> Processing
                                        </button>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <i class="fas fa-star text-info"></i>
                                        First Donation Certificate
                                    </td>
                                    <td>2022-01-15</td>
                                    <td>2022-01-16</td>
                                    <td><span class="badge bg-success">Ready</span></td>
                                    <td>
                                        <a href="#" class="btn btn-sm btn-primary">
                                            <i class="fas fa-download"></i> Download PDF
                                        </a>
                                        <a href="#" class="btn btn-sm btn-outline-secondary">
                                            <i class="fas fa-eye"></i> Preview
                                        </a>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h6><i class="fas fa-info-circle"></i> Certificate Information</h6>
                </div>
                <div class="card-body">
                    <p class="small">
                        <strong>Certificate Types:</strong>
                    </p>
                    <ul class="list-unstyled small">
                        <li><i class="fas fa-certificate text-primary"></i> Blood Donation Certificate - Issued after each donation</li>
                        <li><i class="fas fa-medal text-success"></i> Achievement Certificates - Milestone rewards</li>
                        <li><i class="fas fa-trophy text-warning"></i> Special Recognition - Outstanding contributions</li>
                    </ul>
                    
                    <hr>
                    
                    <p class="small">
                        <strong>Download Options:</strong>
                    </p>
                    <ul class="list-unstyled small">
                        <li><i class="fas fa-file-pdf text-danger"></i> PDF Format</li>
                        <li><i class="fas fa-image text-info"></i> High-resolution Image</li>
                        <li><i class="fas fa-print text-secondary"></i> Print-ready Version</li>
                    </ul>
                </div>
            </div>
            
            <div class="card mt-3">
                <div class="card-header">
                    <h6><i class="fas fa-share-alt"></i> Share Your Achievement</h6>
                </div>
                <div class="card-body">
                    <p class="small">Share your donation achievements on social media:</p>
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-primary btn-sm">
                            <i class="fab fa-facebook"></i> Share on Facebook
                        </button>
                        <button class="btn btn-outline-info btn-sm">
                            <i class="fab fa-twitter"></i> Share on Twitter
                        </button>
                        <button class="btn btn-outline-success btn-sm">
                            <i class="fab fa-whatsapp"></i> Share on WhatsApp
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="card mt-3">
                <div class="card-header">
                    <h6><i class="fas fa-question-circle"></i> Need Help?</h6>
                </div>
                <div class="card-body">
                    <p class="small">
                        If you have issues downloading your certificates or need a replacement, please contact our support team.
                    </p>
                    <a href="mailto:support@blooddonation.org" class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-envelope"></i> Contact Support
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-trophy"></i> Achievement Progress</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="text-center">
                                <div class="progress mb-2" style="height: 10px;">
                                    <div class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
                                </div>
                                <i class="fas fa-check-circle text-success fa-2x"></i>
                                <p class="small mt-1"><strong>First Donation</strong><br>Completed</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <div class="progress mb-2" style="height: 10px;">
                                    <div class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
                                </div>
                                <i class="fas fa-star text-warning fa-2x"></i>
                                <p class="small mt-1"><strong>5 Donations</strong><br>Completed</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <div class="progress mb-2" style="height: 10px;">
                                    <div class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
                                </div>
                                <i class="fas fa-medal text-success fa-2x"></i>
                                <p class="small mt-1"><strong>10 Donations</strong><br>Completed</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <div class="progress mb-2" style="height: 10px;">
                                    <div class="progress-bar bg-warning" role="progressbar" style="width: 60%"></div>
                                </div>
                                <i class="fas fa-crown text-muted fa-2x"></i>
                                <p class="small mt-1"><strong>20 Donations</strong><br>12/20 Complete</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>