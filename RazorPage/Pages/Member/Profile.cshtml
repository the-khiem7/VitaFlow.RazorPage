@page
@model RazorPage.Pages.Member.ProfileModel
@{
    ViewData["Title"] = "My Profile";
}

<style>
    .admin-container {
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        min-height: 100vh;
        padding: 2rem 0;
    }

    .page-header {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        border-radius: 20px;
        padding: 2.5rem;
        margin-bottom: 2rem;
        text-align: center;
    }

    .header-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        box-shadow: 0 8px 16px rgba(59, 130, 246, 0.2);
    }

    .modern-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        border-radius: 16px;
        transition: all 0.3s ease;
    }

    .form-control, .form-select {
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        padding: 12px 16px;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.9);
    }

    .form-control:focus, .form-select:focus {
        box-shadow: 0 0 0 0.2rem rgba(59, 130, 246, 0.2);
        border-color: #3b82f6;
        background: #ffffff;
    }

    .btn-modern {
        background: linear-gradient(135deg, #10b981, #059669);
        border: none;
        color: white;
        font-weight: 600;
        padding: 12px 24px;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    .btn-modern:hover {
        background: linear-gradient(135deg, #059669, #047857);
        transform: translateY(-1px);
        color: white;
    }

    .btn-secondary-modern {
        background: #ffffff;
        border: 1.5px solid #e2e8f0;
        color: #374151;
        font-weight: 600;
        padding: 12px 24px;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    .btn-secondary-modern:hover {
        background: #f9fafb;
        border-color: #d1d5db;
        color: #374151;
        transform: translateY(-1px);
    }

    .btn-warning-modern {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        border: none;
        color: white;
        font-weight: 600;
        padding: 12px 24px;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    .btn-warning-modern:hover {
        background: linear-gradient(135deg, #d97706, #b45309);
        transform: translateY(-1px);
        color: white;
    }

    .profile-image {
        border: 4px solid #ffffff;
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
    }

    .subtle-pattern {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0.03;
        background-image: radial-gradient(circle at 20% 20%, #3b82f6 1px, transparent 1px);
        background-size: 30px 30px;
    }

    .form-check-input:checked {
        background-color: #3b82f6;
        border-color: #3b82f6;
    }

    .badge {
        font-size: 0.9rem;
        padding: 8px 12px;
        border-radius: 8px;
    }
</style>

<div class="admin-container position-relative">
    <div class="subtle-pattern"></div>

    <div class="container position-relative">
        <div class="page-header">
            <div class="header-icon">
                <i class="fas fa-user-circle text-white" style="font-size: 2rem;"></i>
            </div>
            <h1 class="fw-bold text-dark mb-2" style="font-size: 2.8rem;">My Profile</h1>
            <p class="text-muted mb-0" style="font-size: 1.2rem;">Manage your personal information and preferences</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="modern-card mb-4">
                    <div class="card-header bg-transparent border-0 text-center py-4">
                        <h5 class="mb-0 text-dark"><i class="fas fa-user-circle text-primary me-2"></i> Profile Picture</h5>
                    </div>
                    <div class="card-body text-center py-4">
                        <img src="https://via.placeholder.com/150x150/dc3545/ffffff?text=User"
                             class="rounded-circle mb-3 profile-image"
                             alt="Profile Picture" width="150" height="150">
                        <br>
                        <button class="btn btn-secondary-modern btn-sm px-3">
                            <i class="fas fa-camera me-2"></i> Change Photo
                        </button>
                    </div>
                </div>

                <div class="modern-card">
                    <div class="card-header bg-transparent border-0 py-3">
                        <h6 class="mb-0 text-dark"><i class="fas fa-tint text-danger me-2"></i> Blood Information</h6>
                    </div>
                    <div class="card-body py-3">
                        <p><strong>Blood Type:</strong> <span class="badge bg-danger">@((string.IsNullOrEmpty(Model.BloodType) ? "Unknown" : Model.BloodType))</span></p>
                        <p><strong>Donor Status:</strong> <span class="badge @(Model.IsDonor ? "bg-success" : "bg-secondary")">@((Model.IsDonor ? "Active" : "Inactive"))</span></p>
                        <p><strong>Member Since:</strong> @Model.MemberSince.ToString("MMMM yyyy")</p>
                        <p class="mb-0"><strong>Total Donations:</strong> @Model.TotalDonations</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="modern-card mb-4">
                    <div class="card-header bg-transparent border-0 py-3">
                        <h5 class="mb-0 text-dark"><i class="fas fa-edit text-primary me-2"></i> Personal Information</h5>
                    </div>
                    <div class="card-body py-3">
                        <form method="post" autocomplete="off">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="firstName" class="form-label fw-semibold">First Name</label>
                                    <input type="text" class="form-control" id="firstName" name="FirstName"
                                           value="@Model.FirstName" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="lastName" class="form-label fw-semibold">Last Name</label>
                                    <input type="text" class="form-control" id="lastName" name="LastName"
                                           value="@Model.LastName" required>
                                </div>
                            </div>
                            <div class="row g-3 mt-1">
                                <div class="col-md-6">
                                    <label for="email" class="form-label fw-semibold">Email Address</label>
                                    <input type="email" class="form-control" id="email" name="Email"
                                           value="@Model.Email" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="phone" class="form-label fw-semibold">Phone Number</label>
                                    <input type="tel" class="form-control" id="phone" name="Phone"
                                           value="@Model.Phone" required>
                                </div>
                            </div>
                            <div class="row g-3 mt-1">
                                <div class="col-md-6">
                                    <label for="dateOfBirth" class="form-label fw-semibold">Date of Birth</label>
                                    <input type="date" class="form-control" id="dateOfBirth" name="DateOfBirth"
                                           value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="gender" class="form-label fw-semibold">Gender</label>
                                    <select class="form-select" id="gender" name="Gender" required>
                                        <option value="Male" selected="@(Model.Gender == "Male")">Male</option>
                                        <option value="Female" selected="@(Model.Gender == "Female")">Female</option>
                                        <option value="Other" selected="@(Model.Gender == "Other")">Other</option>
                                        <option value="PreferNotToSay" selected="@(Model.Gender == "PreferNotToSay")">Prefer not to say</option>
                                    </select>
                                </div>
                            </div>
                            <div class="mb-3 mt-3">
                                <label for="address" class="form-label fw-semibold">Address</label>
                                <textarea class="form-control" id="address" name="Address" rows="3" required>@Model.Address</textarea>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="emergencyContact" class="form-label fw-semibold">Emergency Contact Name</label>
                                    <input type="text" class="form-control" id="emergencyContact" name="EmergencyContact"
                                           value="@Model.EmergencyContact">
                                </div>
                                <div class="col-md-6">
                                    <label for="emergencyPhone" class="form-label fw-semibold">Emergency Contact Phone</label>
                                    <input type="tel" class="form-control" id="emergencyPhone" name="EmergencyPhone"
                                           value="@Model.EmergencyPhone">
                                </div>
                            </div>
                            <hr class="my-4">
                            <h6 class="mt-3 text-dark"><i class="fas fa-bell text-warning me-2"></i> Notification Preferences</h6>
                            <div class="row g-3 mt-2">
                                <div class="col-md-6">
                                    <div class="form-check form-switch mb-3">
                                        <input class="form-check-input" type="checkbox" id="emailNotifications"
                                               name="EmailNotifications" @(Model.EmailNotifications ? "checked" : "")>
                                        <label class="form-check-label fw-semibold" for="emailNotifications">
                                            Email Notifications
                                        </label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="smsNotifications"
                                               name="SmsNotifications" @(Model.SmsNotifications ? "checked" : "")>
                                        <label class="form-check-label fw-semibold" for="smsNotifications">
                                            SMS Notifications
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-check form-switch mb-3">
                                        <input class="form-check-input" type="checkbox" id="appointmentReminders"
                                               name="AppointmentReminders" @(Model.AppointmentReminders ? "checked" : "")>
                                        <label class="form-check-label fw-semibold" for="appointmentReminders">
                                            Appointment Reminders
                                        </label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="donationEligibility"
                                               name="DonationEligibility" @(Model.DonationEligibility ? "checked" : "")>
                                        <label class="form-check-label fw-semibold" for="donationEligibility">
                                            Donation Eligibility Alerts
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-4 d-flex gap-2">
                                <button type="submit" class="btn btn-modern px-4">
                                    <i class="fas fa-save me-2"></i> Save Changes
                                </button>
                                <button type="button" class="btn btn-secondary-modern px-4">
                                    <i class="fas fa-undo me-2"></i> Reset
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="modern-card">
                    <div class="card-header bg-transparent border-0 py-3">
                        <h5 class="mb-0 text-dark"><i class="fas fa-key text-warning me-2"></i> Change Password</h5>
                    </div>
                    <div class="card-body py-3">
                        <form method="post" asp-page-handler="ChangePassword" autocomplete="off">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label for="currentPassword" class="form-label fw-semibold">Current Password</label>
                                    <input type="password" class="form-control" id="currentPassword"
                                           name="CurrentPassword" required>
                                </div>
                                <div class="col-md-4">
                                    <label for="newPassword" class="form-label fw-semibold">New Password</label>
                                    <input type="password" class="form-control" id="newPassword"
                                           name="NewPassword" required>
                                </div>
                                <div class="col-md-4">
                                    <label for="confirmPassword" class="form-label fw-semibold">Confirm Password</label>
                                    <input type="password" class="form-control" id="confirmPassword"
                                           name="ConfirmPassword" required>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-warning-modern mt-3 px-4">
                                <i class="fas fa-key me-2"></i> Change Password
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>