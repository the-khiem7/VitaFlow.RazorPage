@page
@model RazorPage.Pages.Donation.RegisterModel
@{
    ViewData["Title"] = "Register for Blood Donation";
}

<style>
    /* Modern Donation Theme */
    .donation-container {
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        min-height: 100vh;
        padding: 2rem 0;
    }

    .page-header {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        border-radius: 20px;
        padding: 2.5rem;
        margin-bottom: 2rem;
        text-align: center;
    }

    .header-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        box-shadow: 0 8px 16px rgba(239, 68, 68, 0.2);
    }

    .donation-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        border-radius: 16px;
        overflow: hidden;
    }

    .form-control-modern {
        background: #ffffff;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        transition: all 0.3s ease;
        padding: 12px;
    }

        .form-control-modern:focus {
            border-color: #ef4444;
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
            background: #ffffff;
        }

    .btn-modern {
        border-radius: 10px;
        padding: 12px 20px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
    }

        .btn-modern:hover {
            transform: translateY(-2px);
        }

    .btn-donation {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
    }

        .btn-donation:hover {
            box-shadow: 0 8px 16px rgba(239, 68, 68, 0.25);
            color: white;
        }

    .card-header-modern {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        padding: 1.5rem;
        border: none;
        color: white;
    }

    .subtle-pattern {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0.03;
        background-image: radial-gradient(circle at 20% 20%, #ef4444 1px, transparent 1px);
        background-size: 30px 30px;
    }
</style>

<div class="donation-container position-relative">
    <div class="subtle-pattern"></div>
    <div class="container position-relative">
        <!-- Page Header -->
        <div class="page-header">
            <div class="header-icon">
                <i class="fas fa-tint text-white" style="font-size: 2rem;"></i>
            </div>
            <h1 class="fw-bold text-dark mb-2" style="font-size: 2.5rem;">Register for Blood Donation</h1>
            <p class="text-muted mb-0" style="font-size: 1.1rem;">Join our community of donors and help save lives</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="donation-card">
                    <div class="card-header-modern">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-clipboard-list me-2"></i>Donation Registration Form</h5>
                    </div>
                    <div class="card-body p-4">
                        <form method="post" class="needs-validation" novalidate>
                            @Html.AntiForgeryToken()

                            <div class="mb-4">
                                <label asp-for="Input.BloodType" class="form-label fw-semibold">Blood Type</label>
                                <select asp-for="Input.BloodType" class="form-select form-control-modern" required>
                                    <option value="">Select Blood Type</option>
                                    <option value="A+">A Positive (A+)</option>
                                    <option value="A-">A Negative (A-)</option>
                                    <option value="B+">B Positive (B+)</option>
                                    <option value="B-">B Negative (B-)</option>
                                    <option value="O+">O Positive (O+)</option>
                                    <option value="O-">O Negative (O-)</option>
                                    <option value="AB+">AB Positive (AB+)</option>
                                    <option value="AB-">AB Negative (AB-)</option>
                                </select>
                                <div class="invalid-feedback">
                                    Please select your blood type.
                                </div>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Input.DonationDate" class="form-label fw-semibold">Preferred Donation Date</label>
                                <input type="date" asp-for="Input.DonationDate" class="form-control form-control-modern" required min="@DateTime.Now.ToString("yyyy-MM-dd")">
                                <div class="invalid-feedback">
                                    Please select a valid donation date.
                                </div>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Input.CurrentMedications" class="form-label fw-semibold">Current Medications</label>
                                <textarea asp-for="Input.CurrentMedications" class="form-control form-control-modern" rows="3" placeholder="List any current medications or write 'None'"></textarea>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Input.Notes" class="form-label fw-semibold">Additional Notes</label>
                                <textarea asp-for="Input.Notes" class="form-control form-control-modern" rows="3" placeholder="Any additional information you would like to share"></textarea>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-donation btn-modern">Register for Donation</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Form validation
        (function () {
            'use strict';
            var forms = document.querySelectorAll('.needs-validation');
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
}