@page
@model RazorPage.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<style>
    .register-container {
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        min-height: 100vh;
        position: relative;
    }
    
    .register-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        border-radius: 20px;
    }
    
    .form-input {
        background: #ffffff;
        border: 1.5px solid #e2e8f0;
        transition: all 0.3s ease;
        font-size: 0.95rem;
        padding: 15px;
        border-radius: 12px;
    }
    
    .form-input:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        background: #ffffff;
    }
    
    .btn-register {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        border: none;
        transition: all 0.3s ease;
        font-weight: 600;
        padding: 16px;
        border-radius: 12px;
    }
    
    .btn-register:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(59, 130, 246, 0.25);
    }
    
    .brand-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        box-shadow: 0 8px 16px rgba(59, 130, 246, 0.2);
    }
    
    .subtle-pattern {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0.03;
        background-image: radial-gradient(circle at 20% 20%, #3b82f6 1px, transparent 1px);
        background-size: 30px 30px;
    }
</style>

<div class="register-container d-flex align-items-center">
    <div class="subtle-pattern"></div>
    
    <div class="container py-5 position-relative">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">
                <div class="register-card">
                    <div class="p-5">
                        <!-- Header -->
                        <div class="text-center mb-5">
                            <div class="brand-icon">
                                <i class="fas fa-heartbeat text-white" style="font-size: 2rem;"></i>
                            </div>
                            <h1 class="fw-bold text-dark mb-2" style="font-size: 2.5rem;">Join VitaFlow</h1>
                            <p class="text-muted mb-0" style="font-size: 1.1rem;">Create your account to start saving lives</p>
                        </div>

                        <form method="post">
                            <div class="row g-4 mb-4">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input asp-for="Input.Email" class="form-control form-input" placeholder="Email" />
                                        <label asp-for="Input.Email" class="text-muted"><i class="fas fa-envelope me-2"></i>Email Address</label>
                                        <span asp-validation-for="Input.Email" class="text-danger mt-2 d-block"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input asp-for="Input.Username" class="form-control form-input" placeholder="Username" />
                                        <label asp-for="Input.Username" class="text-muted"><i class="fas fa-user me-2"></i>Username</label>
                                        <span asp-validation-for="Input.Username" class="text-danger mt-2 d-block"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-4 mb-4">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input asp-for="Input.Password" class="form-control form-input" placeholder="Password" type="password" />
                                        <label asp-for="Input.Password" class="text-muted"><i class="fas fa-lock me-2"></i>Create Password</label>
                                        <span asp-validation-for="Input.Password" class="text-danger mt-2 d-block"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input asp-for="Input.ConfirmPassword" class="form-control form-input" placeholder="Confirm Password" type="password" />
                                        <label asp-for="Input.ConfirmPassword" class="text-muted"><i class="fas fa-lock me-2"></i>Confirm Password</label>
                                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger mt-2 d-block"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-4 mb-4">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input asp-for="Input.FullName" class="form-control form-input" placeholder="Full Name" />
                                        <label asp-for="Input.FullName" class="text-muted"><i class="fas fa-id-card me-2"></i>Full Name</label>
                                        <span asp-validation-for="Input.FullName" class="text-danger mt-2 d-block"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input asp-for="Input.Phone" class="form-control form-input" placeholder="Phone Number" />
                                        <label asp-for="Input.Phone" class="text-muted"><i class="fas fa-phone me-2"></i>Phone Number</label>
                                        <span asp-validation-for="Input.Phone" class="text-danger mt-2 d-block"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-4 mb-5">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input asp-for="Input.UserIdCard" class="form-control form-input" placeholder="ID Card Number" />
                                        <label asp-for="Input.UserIdCard" class="text-muted"><i class="fas fa-id-badge me-2"></i>ID Card Number</label>
                                        <span asp-validation-for="Input.UserIdCard" class="text-danger mt-2 d-block"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input asp-for="Input.DateOfBirth" class="form-control form-input" placeholder="Date of Birth" type="date" />
                                        <label asp-for="Input.DateOfBirth" class="text-muted"><i class="fas fa-calendar me-2"></i>Date of Birth</label>
                                        <span asp-validation-for="Input.DateOfBirth" class="text-danger mt-2 d-block"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="d-grid mb-4">
                                <button type="submit" class="btn btn-register btn-lg text-white">
                                    <i class="fas fa-user-plus me-2"></i>Create Account
                                </button>
                            </div>

                            <div class="text-center">
                                <p class="mb-0 text-muted">Already have an account? 
                                    <a asp-page="/Account/Login" class="text-primary fw-semibold text-decoration-none">Sign in here</a>
                                </p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}