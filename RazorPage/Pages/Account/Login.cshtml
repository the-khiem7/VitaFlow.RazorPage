@page
@model RazorPage.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<style>
    .login-container {
        background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
        min-height: 100vh;
        position: relative;
    }
    
    .login-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        border-radius: 20px;
    }
    
    .login-input {
        background: #ffffff;
        border: 1.5px solid #e2e8f0;
        transition: all 0.3s ease;
        font-size: 0.95rem;
        padding: 15px;
        border-radius: 12px;
    }
    
    .login-input:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        background: #ffffff;
    }
    
    .btn-login {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        border: none;
        transition: all 0.3s ease;
        font-weight: 600;
        padding: 16px;
        border-radius: 12px;
    }
    
    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(59, 130, 246, 0.25);
    }
    
    .btn-google {
        background: #ffffff;
        border: 1.5px solid #e2e8f0;
        color: #374151;
        font-weight: 500;
        padding: 16px;
        border-radius: 12px;
        transition: all 0.3s ease;
    }
    
    .btn-google:hover {
        border-color: #d1d5db;
        background: #f9fafb;
        color: #374151;
        transform: translateY(-1px);
    }
    
    .brand-logo {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        box-shadow: 0 8px 16px rgba(59, 130, 246, 0.2);
    }
    
    .subtle-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0.03;
        background-image: radial-gradient(circle at 25% 25%, #3b82f6 1px, transparent 1px);
        background-size: 25px 25px;
    }
</style>

<div class="login-container d-flex align-items-center">
    <div class="subtle-bg"></div>
    
    <div class="container py-5 position-relative">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-xl-4">
                <div class="login-card">
                    <div class="p-5">
                        <!-- Header -->
                        <div class="text-center mb-5">
                            <div class="brand-logo">
                                <i class="fas fa-heartbeat text-white" style="font-size: 1.8rem;"></i>
                            </div>
                            <h2 class="fw-bold text-dark mb-2" style="font-size: 2.2rem;">Welcome Back</h2>
                            <p class="text-muted mb-0">Sign in to your VitaFlow account</p>
                        </div>

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
                                @TempData["SuccessMessage"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }
                        
                        <form method="post">
                            <div asp-validation-summary="All" class="alert alert-danger rounded-3 mb-4"></div>
                            
                            <div class="mb-4">
                                <div class="form-floating">
                                    <input asp-for="Input.Email" class="form-control login-input" placeholder="Email" />
                                    <label asp-for="Input.Email" class="text-muted"><i class="fas fa-envelope me-2"></i>Email Address</label>
                                    <span asp-validation-for="Input.Email" class="text-danger mt-2 d-block"></span>
                                </div>
                            </div>
                            
                            <div class="mb-4">
                                <div class="form-floating">
                                    <input asp-for="Input.Password" class="form-control login-input" placeholder="Password" type="password" />
                                    <label asp-for="Input.Password" class="text-muted"><i class="fas fa-lock me-2"></i>Password</label>
                                    <span asp-validation-for="Input.Password" class="text-danger mt-2 d-block"></span>
                                </div>
                            </div>
                            
                            <div class="form-check mb-4">
                                <input asp-for="Input.RememberMe" class="form-check-input" type="checkbox" style="accent-color: #3b82f6;" />
                                <label asp-for="Input.RememberMe" class="form-check-label text-muted">Remember me</label>
                            </div>
                            
                            <div class="d-grid mb-4">
                                <button type="submit" class="btn btn-login btn-lg text-white">
                                    <i class="fas fa-sign-in-alt me-2"></i>Sign In
                                </button>
                            </div>
                            
                            <div class="position-relative text-center mb-4">
                                <hr class="text-muted" />
                                <span class="position-absolute top-50 start-50 translate-middle bg-white text-muted px-3">or</span>
                            </div>
                            
                            <div class="d-grid mb-4">
                                <a href="/Account/GoogleLogin" class="btn btn-google btn-lg">
                                    <i class="fab fa-google me-2 text-danger"></i>Continue with Google
                                </a>
                            </div>
                            
                            <div class="text-center">
                                <p class="mb-0 text-muted">Don't have an account? 
                                    <a asp-page="/Account/Register" class="text-primary fw-semibold text-decoration-none">Create one</a>
                                </p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
    </div>
</div>
