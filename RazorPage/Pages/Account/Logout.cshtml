@page
@model RazorPage.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Logout";
}

<style>
    .logout-container {
        background: linear-gradient(135deg, #e0f2fe 0%, #b3e5fc 100%);
        min-height: 100vh;
        position: relative;
    }
    
    .logout-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        border-radius: 20px;
    }
    
    .farewell-icon {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        box-shadow: 0 8px 16px rgba(6, 182, 212, 0.2);
    }
    
    .btn-logout {
        border-radius: 12px;
        padding: 14px 24px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
    }
    
    .btn-logout:hover {
        transform: translateY(-2px);
    }
    
    .btn-primary-logout {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        color: white;
    }
    
    .btn-primary-logout:hover {
        box-shadow: 0 10px 20px rgba(59, 130, 246, 0.25);
        color: white;
    }
    
    .btn-secondary-logout {
        background: #ffffff;
        border: 1.5px solid #e2e8f0;
        color: #374151;
    }
    
    .btn-secondary-logout:hover {
        background: #f9fafb;
        border-color: #d1d5db;
        color: #374151;
    }
</style>

<div class="logout-container d-flex align-items-center">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-xl-5">
                <div class="logout-card">
                    <div class="text-center p-5">
                        <!-- Icon -->
                        <div class="farewell-icon">
                            <i class="fas fa-check-circle text-white" style="font-size: 2.5rem;"></i>
                        </div>
                        
                        <!-- Header -->
                        <h1 class="fw-bold text-dark mb-3" style="font-size: 2.5rem;">See You Soon!</h1>
                        <p class="text-muted mb-4" style="font-size: 1.1rem;">You've been successfully signed out</p>
                        
                        <!-- Message -->
                        <div class="mb-5">
                            <div class="p-4 rounded-3 bg-light">
                                <p class="text-dark mb-2">Thank you for using <strong>VitaFlow</strong></p>
                                <p class="text-muted mb-0">Your session has been securely ended. Every drop counts! 💙</p>
                            </div>
                        </div>
                        
                        <!-- Action buttons -->
                        <div class="d-grid gap-3 mb-4">
                            <a href="/" class="btn btn-logout btn-primary-logout">
                                <i class="fas fa-home me-2"></i>Return to Home
                            </a>
                            
                            <a href="/Account/Login" class="btn btn-logout btn-secondary-logout">
                                <i class="fas fa-sign-in-alt me-2"></i>Sign In Again
                            </a>
                        </div>
                        
                        <!-- Support link -->
                        <div class="mt-4">
                            <p class="small text-muted mb-0">
                                Need assistance? <a href="/Contact" class="text-primary text-decoration-none fw-semibold">Contact our team</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>