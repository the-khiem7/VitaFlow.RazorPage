@page
@model RazorPage.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h1 class="text-danger mb-4"><i class="fas fa-exclamation-triangle"></i> Access Denied</h1>
                    <p class="lead">You do not have permission to access this resource.</p>
                    <p>Please contact the administrator if you believe this is an error.</p>
                    
                    @if (!string.IsNullOrEmpty(Model.ReturnUrl))
                    {
                        <p class="text-muted">You were trying to access: @Model.ReturnUrl</p>
                    }
                    
                    <hr />
                    <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                        <a asp-page="/Index" class="btn btn-primary"><i class="fas fa-home"></i> Home</a>
                        <a asp-page="/Account/Login" class="btn btn-outline-secondary"><i class="fas fa-sign-in-alt"></i> Login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>