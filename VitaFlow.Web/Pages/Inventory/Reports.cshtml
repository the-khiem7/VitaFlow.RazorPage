@page
@model VitaFlow.Web.Pages.Inventory.ReportsModel
@{
    ViewData["Title"] = "Báo cáo kho máu";
}

<div class="max-w-7xl mx-auto p-6">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-3xl font-bold text-blue-700">Báo cáo kho máu</h1>
            <p class="text-gray-600 mt-2">Thống kê và phân tích tình hình tồn kho máu</p>
        </div>
        <div class="flex space-x-3">
            <a asp-page="Index" class="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 transition-colors">
                <i class="fas fa-arrow-left mr-2"></i>Quay lại tổng quan
            </a>
            <button onclick="exportReport()"
                class="px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 transition-colors">
                <i class="fas fa-download mr-2"></i>Xuất báo cáo
            </button>
        </div>
    </div>

    <!-- Report Filters -->
    <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Bộ lọc báo cáo</h3>
        <form method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Từ ngày</label>
                <input type="date" name="fromDate" asp-for="FromDate"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Đến ngày</label>
                <input type="date" name="toDate" asp-for="ToDate"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Loại báo cáo</label>
                <select name="reportType" asp-for="ReportType"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
                    <option value="summary" selected="@(Model.ReportType == "summary")">Tổng quan</option>
                    <option value="bloodtype" selected="@(Model.ReportType == "bloodtype")">Theo nhóm máu</option>
                    <option value="expiry" selected="@(Model.ReportType == "expiry")">Hạn sử dụng</option>
                    <option value="daily" selected="@(Model.ReportType == "daily")">Theo ngày</option>
                </select>
            </div>

            <div class="flex items-end">
                <button type="submit"
                    class="w-full px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-colors">
                    <i class="fas fa-chart-bar mr-2"></i>Tạo báo cáo
                </button>
            </div>
        </form>
    </div>

    <!-- Summary Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white rounded-lg shadow-lg p-6 border-l-4 border-blue-500">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                        <i class="fas fa-tint text-blue-500 text-xl"></i>
                    </div>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-gray-600">Tổng thể tích</p>
                    <p class="text-2xl font-bold text-gray-900">@Model.TotalVolume.ToString("F0") ml</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 border-l-4 border-green-500">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                        <i class="fas fa-check-circle text-green-500 text-xl"></i>
                    </div>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-gray-600">Đơn vị sẵn sàng</p>
                    <p class="text-2xl font-bold text-gray-900">@Model.AvailableUnits</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 border-l-4 border-yellow-500">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center">
                        <i class="fas fa-exclamation-triangle text-yellow-500 text-xl"></i>
                    </div>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-gray-600">Sắp hết hạn</p>
                    <p class="text-2xl font-bold text-gray-900">@Model.ExpiringUnits</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 border-l-4 border-red-500">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center">
                        <i class="fas fa-times-circle text-red-500 text-xl"></i>
                    </div>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-gray-600">Đã hết hạn</p>
                    <p class="text-2xl font-bold text-gray-900">@Model.ExpiredUnits</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Tables Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <!-- Blood Type Distribution Table -->
        <div class="bg-white rounded-lg shadow-lg p-6">
            <h3 class="text-lg font-bold text-gray-800 mb-4">Phân bố theo nhóm máu</h3>
            @if (Model.BloodTypeStats?.Any() == true)
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nhóm máu</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Thể tích (ml)
                                </th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var stat in Model.BloodTypeStats.OrderBy(x => x.Key))
                            {
                                <tr>
                                    <td class="px-4 py-4 whitespace-nowrap">
                                        <span class="text-lg font-bold text-red-500">@stat.Key</span>
                                    </td>
                                    <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                                        @stat.Value.TotalVolume.ToString("F0") ml
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-gray-500 text-center py-8">Không có dữ liệu</p>
            }
        </div>

        <!-- Volume Breakdown Table -->
        <div class="bg-white rounded-lg shadow-lg p-6">
            <h3 class="text-lg font-bold text-gray-800 mb-4">Phân loại thành phần máu</h3>
            <div class="space-y-4">
                <div class="flex justify-between items-center p-3 bg-red-50 rounded">
                    <span class="font-medium text-gray-700">Máu toàn phần:</span>
                    <span class="font-bold text-red-600">@Model.TotalWholeBlood.ToString("F0") ml</span>
                </div>
                <div class="flex justify-between items-center p-3 bg-red-100 rounded">
                    <span class="font-medium text-gray-700">Hồng cầu:</span>
                    <span class="font-bold text-red-700">@Model.TotalRedCells.ToString("F0") ml</span>
                </div>
                <div class="flex justify-between items-center p-3 bg-red-50 rounded">
                    <span class="font-medium text-gray-700">Huyết tương:</span>
                    <span class="font-bold text-red-600">@Model.TotalPlasma.ToString("F0") ml</span>
                </div>
                <div class="flex justify-between items-center p-3 bg-red-100 rounded">
                    <span class="font-medium text-gray-700">Tiểu cầu:</span>
                    <span class="font-bold text-red-700">@Model.TotalPlatelets.ToString("F0") ml</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Blood Type Statistics Table -->
    @if (Model.BloodTypeStats?.Any() == true)
    {
        <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
            <h3 class="text-lg font-bold text-gray-800 mb-4">Thống kê chi tiết theo nhóm máu</h3>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Nhóm máu
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Tổng thể tích
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Tổng đơn vị
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Sẵn sàng
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Sắp hết hạn
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Máu toàn phần
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Thành phần máu
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var stat in Model.BloodTypeStats.Values.OrderBy(s => s.BloodType))
                        {
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-xl font-bold text-red-500">@stat.BloodType</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                    @stat.TotalVolume.ToString("F0") ml
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                    @stat.TotalUnits
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                    <span class="text-green-600 font-semibold">@stat.AvailableUnits</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                    <span class="text-yellow-600 font-semibold">@stat.ExpiringUnits</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                    @stat.WholeBloodVolume.ToString("F0") ml
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                    @stat.ComponentsVolume.ToString("F0") ml
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Daily Reports -->
    @if (Model.ReportType == "daily" && Model.DailyReports?.Any() == true)
    {
        <div class="bg-white rounded-lg shadow-lg p-6">
            <h3 class="text-lg font-bold text-gray-800 mb-4">Báo cáo theo ngày</h3>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Ngày
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Đơn vị thêm vào
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Đơn vị sử dụng
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Đơn vị hết hạn
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Thể tích thêm vào
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Thể tích sử dụng
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var report in Model.DailyReports.OrderByDescending(r => r.Date))
                        {
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-medium">
                                    @report.Date.ToString("dd/MM/yyyy")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 font-semibold">
                                    +@report.UnitsAdded
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-blue-600 font-semibold">
                                    -@report.UnitsUsed
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600 font-semibold">
                                    -@report.UnitsExpired
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600">
                                    +@report.VolumeAdded.ToString("F0") ml
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-blue-600">
                                    -@report.VolumeUsed.ToString("F0") ml
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- JavaScript for Export -->
<script>
    function exportReport() {
        const params = new URLSearchParams({
            fromDate: '@Model.FromDate.ToString("yyyy-MM-dd")',
            toDate: '@Model.ToDate.ToString("yyyy-MM-dd")',
            reportType: '@Model.ReportType'
        });

        window.location.href = `/Inventory/ExportReport?${params.toString()}`;
    }
</script>

<!-- Font Awesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
