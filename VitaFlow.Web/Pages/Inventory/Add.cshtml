@page
@model VitaFlow.Web.Pages.Inventory.AddModel
@{
    ViewData["Title"] = "Thêm máu vào kho";
}

<div class="max-w-4xl mx-auto p-6">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-3xl font-bold text-blue-700">Thêm máu vào kho</h1>
            <p class="text-gray-600 mt-2">Nhập thông tin máu mới thu thập để thêm vào kho</p>
        </div>
        <a asp-page="Index" class="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 transition-colors">
            <i class="fas fa-arrow-left mr-2"></i>Quay lại
        </a>
    </div>

    <!-- Add Form -->
    <div class="bg-white rounded-lg shadow-lg p-8">
        <form method="post" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-600"></div>
            
            <!-- Blood Type -->
            <div>
                <label asp-for="InventoryData.BloodType" class="block text-sm font-medium text-gray-700 mb-2">
                    Nhóm máu <span class="text-red-500">*</span>
                </label>
                <select asp-for="InventoryData.BloodType" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
                    <option value="">-- Chọn nhóm máu --</option>
                    @foreach (var type in Enum.GetValues(typeof(VitaFlow.Core.Enums.BloodType)))
                    {
                        <option value="@type">@type</option>
                    }
                </select>
                <span asp-validation-for="InventoryData.BloodType" class="text-red-500 text-sm"></span>
            </div>

            <!-- Volume Section -->
            <div class="bg-gray-50 p-6 rounded-lg">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Thể tích máu (ml)</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="InventoryData.WholeBloodVolume" class="block text-sm font-medium text-gray-700 mb-2">
                            Máu toàn phần <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="InventoryData.WholeBloodVolume" type="number" step="0.1" min="0" max="5000"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                               placeholder="450" />
                        <span asp-validation-for="InventoryData.WholeBloodVolume" class="text-red-500 text-sm"></span>
                    </div>
                    
                    <div>
                        <label asp-for="InventoryData.RedCellsVolume" class="block text-sm font-medium text-gray-700 mb-2">
                            Hồng cầu
                        </label>
                        <input asp-for="InventoryData.RedCellsVolume" type="number" step="0.1" min="0" max="5000"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                               placeholder="200" />
                        <span asp-validation-for="InventoryData.RedCellsVolume" class="text-red-500 text-sm"></span>
                    </div>
                    
                    <div>
                        <label asp-for="InventoryData.PlasmaVolume" class="block text-sm font-medium text-gray-700 mb-2">
                            Huyết tương
                        </label>
                        <input asp-for="InventoryData.PlasmaVolume" type="number" step="0.1" min="0" max="5000"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                               placeholder="250" />
                        <span asp-validation-for="InventoryData.PlasmaVolume" class="text-red-500 text-sm"></span>
                    </div>
                    
                    <div>
                        <label asp-for="InventoryData.PlateletsVolume" class="block text-sm font-medium text-gray-700 mb-2">
                            Tiểu cầu
                        </label>
                        <input asp-for="InventoryData.PlateletsVolume" type="number" step="0.1" min="0" max="5000"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                               placeholder="50" />
                        <span asp-validation-for="InventoryData.PlateletsVolume" class="text-red-500 text-sm"></span>
                    </div>
                </div>
                
                <!-- Total Volume Display -->
                <div class="mt-4 p-3 bg-blue-50 rounded-lg">
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-medium text-gray-700">Tổng thể tích:</span>
                        <span id="totalVolume" class="text-lg font-bold text-blue-600">0 ml</span>
                    </div>
                </div>
            </div>

            <!-- Dates -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="InventoryData.CollectionDate" class="block text-sm font-medium text-gray-700 mb-2">
                        Ngày thu thập <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="InventoryData.CollectionDate" type="date"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" />
                    <span asp-validation-for="InventoryData.CollectionDate" class="text-red-500 text-sm"></span>
                </div>
                
                <div>
                    <label asp-for="InventoryData.ExpiryDate" class="block text-sm font-medium text-gray-700 mb-2">
                        Ngày hết hạn <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="InventoryData.ExpiryDate" type="date"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" />
                    <span asp-validation-for="InventoryData.ExpiryDate" class="text-red-500 text-sm"></span>
                    <p class="text-xs text-gray-500 mt-1">Thường là 35-42 ngày sau ngày thu thập</p>
                </div>
            </div>

            <!-- Storage Information -->
            <div class="bg-gray-50 p-6 rounded-lg">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Thông tin lưu trữ</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="InventoryData.StorageLocation" class="block text-sm font-medium text-gray-700 mb-2">
                            Vị trí lưu trữ <span class="text-red-500">*</span>
                        </label>
                        <select asp-for="InventoryData.StorageLocation" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
                            <option value="">-- Chọn vị trí --</option>
                            <option value="Kho A - Tủ 1">Kho A - Tủ 1</option>
                            <option value="Kho A - Tủ 2">Kho A - Tủ 2</option>
                            <option value="Kho B - Tủ 1">Kho B - Tủ 1</option>
                            <option value="Kho B - Tủ 2">Kho B - Tủ 2</option>
                            <option value="Kho C - Tủ 1">Kho C - Tủ 1</option>
                            <option value="Kho C - Tủ 2">Kho C - Tủ 2</option>
                        </select>
                        <span asp-validation-for="InventoryData.StorageLocation" class="text-red-500 text-sm"></span>
                    </div>
                    
                    <div>
                        <label asp-for="InventoryData.BatchNumber" class="block text-sm font-medium text-gray-700 mb-2">
                            Số lô <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="InventoryData.BatchNumber" type="text"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
                               placeholder="VD: BLD240726001" />
                        <span asp-validation-for="InventoryData.BatchNumber" class="text-red-500 text-sm"></span>
                        <p class="text-xs text-gray-500 mt-1">Mã định danh duy nhất cho lô máu này</p>
                    </div>
                </div>
            </div>

            <!-- Availability -->
            <div class="flex items-center">
                <input asp-for="InventoryData.IsAvailable" type="checkbox" 
                       class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" />
                <label asp-for="InventoryData.IsAvailable" class="ml-2 block text-sm text-gray-700">
                    Sẵn sàng sử dụng
                </label>
            </div>

            <!-- Form Actions -->
            <div class="flex justify-end space-x-4 pt-6 border-t border-gray-200">
                <a asp-page="Index" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
                    Hủy
                </a>
                <button type="button" onclick="generateBatchNumber()" class="px-6 py-2 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600 transition-colors">
                    Tạo mã lô tự động
                </button>
                <button type="submit" class="px-6 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-colors">
                    <i class="fas fa-save mr-2"></i>Thêm vào kho
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // Auto-calculate total volume
    function updateTotalVolume() {
        const wholeBlood = parseFloat(document.querySelector('[name="InventoryData.WholeBloodVolume"]').value) || 0;
        const redCells = parseFloat(document.querySelector('[name="InventoryData.RedCellsVolume"]').value) || 0;
        const plasma = parseFloat(document.querySelector('[name="InventoryData.PlasmaVolume"]').value) || 0;
        const platelets = parseFloat(document.querySelector('[name="InventoryData.PlateletsVolume"]').value) || 0;
        
        const total = wholeBlood + redCells + plasma + platelets;
        document.getElementById('totalVolume').textContent = total.toFixed(1) + ' ml';
    }

    // Auto-update expiry date when collection date changes
    function updateExpiryDate() {
        const collectionDate = new Date(document.querySelector('[name="InventoryData.CollectionDate"]').value);
        if (collectionDate) {
            const expiryDate = new Date(collectionDate);
            expiryDate.setDate(expiryDate.getDate() + 35); // 35 days shelf life
            
            const expiryInput = document.querySelector('[name="InventoryData.ExpiryDate"]');
            expiryInput.value = expiryDate.toISOString().split('T')[0];
        }
    }

    // Generate batch number
    function generateBatchNumber() {
        const now = new Date();
        const year = now.getFullYear().toString().slice(-2);
        const month = (now.getMonth() + 1).toString().padStart(2, '0');
        const day = now.getDate().toString().padStart(2, '0');
        const random = Math.floor(Math.random() * 1000).toString().padStart(3, '0');
        
        const batchNumber = `BLD${year}${month}${day}${random}`;
        document.querySelector('[name="InventoryData.BatchNumber"]').value = batchNumber;
    }

    // Event listeners
    document.addEventListener('DOMContentLoaded', function() {
        // Volume inputs
        const volumeInputs = [
            '[name="InventoryData.WholeBloodVolume"]',
            '[name="InventoryData.RedCellsVolume"]',
            '[name="InventoryData.PlasmaVolume"]',
            '[name="InventoryData.PlateletsVolume"]'
        ];
        
        volumeInputs.forEach(selector => {
            const input = document.querySelector(selector);
            if (input) {
                input.addEventListener('input', updateTotalVolume);
            }
        });
        
        // Collection date
        const collectionInput = document.querySelector('[name="InventoryData.CollectionDate"]');
        if (collectionInput) {
            collectionInput.addEventListener('change', updateExpiryDate);
        }
        
        // Initial calculation
        updateTotalVolume();
    });
</script>

<!-- Font Awesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
