@page
@model VitaFlow.Web.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="max-w-7xl mx-auto p-6">
    <!-- Header -->
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">👥 Quản lý người dùng</h1>
            <p class="text-gray-600 mt-2">Quản lý tài khoản và phân quyền người dùng trong hệ thống</p>
        </div>
        <div class="flex space-x-3">
            <a asp-page="Dashboard" class="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 transition-colors">
                <i class="fas fa-arrow-left mr-2"></i>Quay lại Dashboard
            </a>
            <a asp-page="CreateUser" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-colors">
                <i class="fas fa-plus mr-2"></i>Tạo người dùng mới
            </a>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6">
            <i class="fas fa-check-circle mr-2"></i>@Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
            <i class="fas fa-exclamation-circle mr-2"></i>@Model.ErrorMessage
        </div>
    }

    <!-- User Statistics -->
    @if (Model.UserManagement.UserCountSummary?.Any() == true)
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            @foreach (var roleCount in Model.UserManagement.UserCountSummary)
            {
                var roleClass = roleCount.Key switch
                {
                    VitaFlow.Core.Enums.UserRole.Admin => "border-red-500 bg-red-50 text-red-700",
                    VitaFlow.Core.Enums.UserRole.Staff => "border-blue-500 bg-blue-50 text-blue-700",
                    VitaFlow.Core.Enums.UserRole.Donor => "border-green-500 bg-green-50 text-green-700",
                    VitaFlow.Core.Enums.UserRole.Recipient => "border-purple-500 bg-purple-50 text-purple-700",
                    _ => "border-gray-500 bg-gray-50 text-gray-700"
                };
                var roleDisplayName = roleCount.Key switch
                {
                    VitaFlow.Core.Enums.UserRole.Admin => "Quản trị viên",
                    VitaFlow.Core.Enums.UserRole.Staff => "Nhân viên",
                    VitaFlow.Core.Enums.UserRole.Donor => "Người hiến máu",
                    VitaFlow.Core.Enums.UserRole.Recipient => "Người nhận máu",
                    _ => roleCount.Key.ToString()
                };
                <div class="p-6 rounded-lg border-l-4 @roleClass">
                    <div class="text-2xl font-bold">@roleCount.Value</div>
                    <div class="text-sm font-medium">@roleDisplayName</div>
                </div>
            }
        </div>
    }

    <!-- Search and Filter -->
    <div class="bg-white p-6 rounded-lg shadow mb-6">
        <form method="get" class="flex flex-wrap gap-4 items-end">
            <div class="flex-1 min-w-64">
                <label for="searchTerm" class="block text-sm font-medium text-gray-700 mb-2">Tìm kiếm</label>
                <input type="text" id="searchTerm" name="searchTerm" value="@Model.SearchTerm" 
                       placeholder="Nhập tên, email hoặc số điện thoại..." 
                       class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="roleFilter" class="block text-sm font-medium text-gray-700 mb-2">Vai trò</label>
                <select id="roleFilter" name="roleFilter" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">Tất cả vai trò</option>
                    <option value="@VitaFlow.Core.Enums.UserRole.Admin" @(Model.RoleFilter == VitaFlow.Core.Enums.UserRole.Admin ? "selected" : "")>Quản trị viên</option>
                    <option value="@VitaFlow.Core.Enums.UserRole.Staff" @(Model.RoleFilter == VitaFlow.Core.Enums.UserRole.Staff ? "selected" : "")>Nhân viên</option>
                    <option value="@VitaFlow.Core.Enums.UserRole.Donor" @(Model.RoleFilter == VitaFlow.Core.Enums.UserRole.Donor ? "selected" : "")>Người hiến máu</option>
                    <option value="@VitaFlow.Core.Enums.UserRole.Recipient" @(Model.RoleFilter == VitaFlow.Core.Enums.UserRole.Recipient ? "selected" : "")>Người nhận máu</option>
                </select>
            </div>
            <div class="flex space-x-2">
                <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600 transition-colors">
                    <i class="fas fa-search mr-2"></i>Tìm kiếm
                </button>
                <a asp-page="Users" class="px-4 py-2 bg-gray-500 text-white rounded-md hover:bg-gray-600 transition-colors">
                    <i class="fas fa-times mr-2"></i>Xóa bộ lọc
                </a>
            </div>
        </form>
    </div>

    <!-- Users Table -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-medium text-gray-900">
                Danh sách người dùng 
                @if (Model.UserManagement.TotalUsers > 0)
                {
                    <span class="text-sm text-gray-500">(@Model.UserManagement.TotalUsers người dùng)</span>
                }
            </h3>
        </div>

        @if (Model.UserManagement.Users?.Any() == true)
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Người dùng</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Liên hệ</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Vai trò</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ngày tạo</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var user in Model.UserManagement.Users)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-10 w-10">
                                            <div class="h-10 w-10 rounded-full bg-blue-500 flex items-center justify-center">
                                                <span class="text-white font-medium text-sm">@user.FirstName.Substring(0, 1)@user.LastName.Substring(0, 1)</span>
                                            </div>
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-medium text-gray-900">@user.FullName</div>
                                            <div class="text-sm text-gray-500">ID: @user.Id.ToString().Substring(0, 8)...</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-gray-900">@user.Email</div>
                                    <div class="text-sm text-gray-500">@user.PhoneNumber</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full @GetRoleBadgeClass(user.Role)">
                                        @user.RoleDisplayName
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    @user.CreatedAt.ToString("dd/MM/yyyy")
                                    @if (user.UpdatedAt.HasValue)
                                    {
                                        <div class="text-xs text-gray-400">Cập nhật: @user.UpdatedAt.Value.ToString("dd/MM/yyyy")</div>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium space-x-2">
                                    <a asp-page="EditUser" asp-route-id="@user.Id" class="text-blue-600 hover:text-blue-900">
                                        <i class="fas fa-edit mr-1"></i>Sửa
                                    </a>
                                    
                                    <!-- Role Change Dropdown -->
                                    <div class="inline-block relative">
                                        <button type="button" class="text-green-600 hover:text-green-900 dropdown-toggle" data-dropdown-id="role-@user.Id">
                                            <i class="fas fa-user-tag mr-1"></i>Vai trò
                                        </button>
                                        <div id="role-@user.Id" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg z-10 border">
                                            @foreach (VitaFlow.Core.Enums.UserRole role in Enum.GetValues<VitaFlow.Core.Enums.UserRole>())
                                            {
                                                @if (role != user.Role)
                                                {
                                                    <form method="post" asp-page-handler="ChangeRole" class="inline">
                                                        <input type="hidden" name="userId" value="@user.Id" />
                                                        <input type="hidden" name="newRole" value="@role" />
                                                        <button type="submit" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100"
                                                                onclick="return confirm('Bạn có chắc chắn muốn thay đổi vai trò người dùng này?')">
                                                            @GetRoleDisplayName(role)
                                                        </button>
                                                    </form>
                                                }
                                            }
                                        </div>
                                    </div>

                                    <form method="post" asp-page-handler="Delete" class="inline">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="text-red-600 hover:text-red-900"
                                                onclick="return confirm('Bạn có chắc chắn muốn xóa người dùng này? Thao tác này không thể hoàn tác.')">
                                            <i class="fas fa-trash mr-1"></i>Xóa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.UserManagement.TotalPages > 1)
            {
                <div class="bg-white px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6">
                    <div class="flex-1 flex justify-between sm:hidden">
                        @if (Model.CurrentPage > 1)
                        {
                            <a asp-page="Users" asp-route-currentPage="@(Model.CurrentPage - 1)" asp-route-searchTerm="@Model.SearchTerm" asp-route-roleFilter="@Model.RoleFilter"
                               class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                                Trước
                            </a>
                        }
                        @if (Model.CurrentPage < Model.UserManagement.TotalPages)
                        {
                            <a asp-page="Users" asp-route-currentPage="@(Model.CurrentPage + 1)" asp-route-searchTerm="@Model.SearchTerm" asp-route-roleFilter="@Model.RoleFilter"
                               class="ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                                Sau
                            </a>
                        }
                    </div>
                    <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                        <div>
                            <p class="text-sm text-gray-700">
                                Hiển thị <span class="font-medium">@((Model.CurrentPage - 1) * Model.UserManagement.PageSize + 1)</span>
                                đến <span class="font-medium">@Math.Min(Model.CurrentPage * Model.UserManagement.PageSize, Model.UserManagement.TotalUsers)</span>
                                trong <span class="font-medium">@Model.UserManagement.TotalUsers</span> kết quả
                            </p>
                        </div>
                        <div>
                            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px">
                                @for (int i = 1; i <= Model.UserManagement.TotalPages; i++)
                                {
                                    @if (i == Model.CurrentPage)
                                    {
                                        <span class="relative inline-flex items-center px-4 py-2 border border-blue-500 bg-blue-500 text-sm font-medium text-white">
                                            @i
                                        </span>
                                    }
                                    else
                                    {
                                        <a asp-page="Users" asp-route-currentPage="@i" asp-route-searchTerm="@Model.SearchTerm" asp-route-roleFilter="@Model.RoleFilter"
                                           class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                            @i
                                        </a>
                                    }
                                }
                            </nav>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-12">
                <i class="fas fa-users text-gray-400 text-4xl mb-4"></i>
                <h3 class="text-lg font-medium text-gray-900 mb-2">Không tìm thấy người dùng</h3>
                <p class="text-gray-500 mb-4">Không có người dùng nào phù hợp với điều kiện tìm kiếm.</p>
                <a asp-page="CreateUser" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700">
                    <i class="fas fa-plus mr-2"></i>Tạo người dùng đầu tiên
                </a>
            </div>
        }
    </div>
</div>

<!-- Include FontAwesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<!-- Dropdown Script -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Handle dropdown toggles
        document.querySelectorAll('.dropdown-toggle').forEach(function(toggle) {
            toggle.addEventListener('click', function(e) {
                e.preventDefault();
                const dropdownId = this.getAttribute('data-dropdown-id');
                const dropdown = document.getElementById(dropdownId);
                
                // Close all other dropdowns
                document.querySelectorAll('[id^="role-"]').forEach(function(d) {
                    if (d.id !== dropdownId) {
                        d.classList.add('hidden');
                    }
                });
                
                // Toggle current dropdown
                dropdown.classList.toggle('hidden');
            });
        });

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.dropdown-toggle') && !e.target.closest('[id^="role-"]')) {
                document.querySelectorAll('[id^="role-"]').forEach(function(dropdown) {
                    dropdown.classList.add('hidden');
                });
            }
        });
    });
</script>

@functions {
    private string GetRoleBadgeClass(VitaFlow.Core.Enums.UserRole role)
    {
        return role switch
        {
            VitaFlow.Core.Enums.UserRole.Admin => "bg-red-100 text-red-800",
            VitaFlow.Core.Enums.UserRole.Staff => "bg-blue-100 text-blue-800",
            VitaFlow.Core.Enums.UserRole.Donor => "bg-green-100 text-green-800",
            VitaFlow.Core.Enums.UserRole.Recipient => "bg-purple-100 text-purple-800",
            _ => "bg-gray-100 text-gray-800"
        };
    }

    private string GetRoleDisplayName(VitaFlow.Core.Enums.UserRole role)
    {
        return role switch
        {
            VitaFlow.Core.Enums.UserRole.Admin => "Quản trị viên",
            VitaFlow.Core.Enums.UserRole.Staff => "Nhân viên",
            VitaFlow.Core.Enums.UserRole.Donor => "Người hiến máu",
            VitaFlow.Core.Enums.UserRole.Recipient => "Người nhận máu",
            _ => role.ToString()
        };
    }
}
