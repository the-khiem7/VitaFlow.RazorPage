@page
@model VitaFlow.Web.Pages.Admin.SettingsModel
@{
    ViewData["Title"] = "Cài đặt hệ thống";
}

<div class="max-w-7xl mx-auto p-6">
    <!-- Header -->
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">⚙️ Cài đặt hệ thống</h1>
            <p class="text-gray-600 mt-2">Quản lý cấu hình và trạng thái hệ thống VitaFlow</p>
        </div>
        <div>
            <a asp-page="Dashboard" class="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 transition-colors">
                <i class="fas fa-arrow-left mr-2"></i>Quay lại Dashboard
            </a>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6">
            <i class="fas fa-check-circle mr-2"></i>@Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
            <i class="fas fa-exclamation-circle mr-2"></i>@Model.ErrorMessage
        </div>
    }

    <!-- System Status -->
    <div class="bg-white p-6 rounded-lg shadow mb-8">
        <h3 class="text-xl font-semibold text-gray-900 mb-6">
            <i class="fas fa-heartbeat mr-2 text-green-600"></i>
            Trạng thái hệ thống
        </h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Database Status -->
            <div class="flex items-center p-4 bg-gray-50 rounded-lg">
                <div class="flex-shrink-0">
                    <i class="fas fa-database text-2xl @(Model.SystemStatus.IsDatabaseConnected ? "text-green-500" : "text-red-500")"></i>
                </div>
                <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900">Cơ sở dữ liệu</div>
                    <div class="text-sm text-gray-500">@Model.SystemStatus.DatabaseVersion</div>
                    <div class="text-xs @(Model.SystemStatus.IsDatabaseConnected ? "text-green-600" : "text-red-600")">
                        @(Model.SystemStatus.IsDatabaseConnected ? "Kết nối bình thường" : "Mất kết nối")
                    </div>
                </div>
            </div>

            <!-- Application Info -->
            <div class="flex items-center p-4 bg-gray-50 rounded-lg">
                <div class="flex-shrink-0">
                    <i class="fas fa-code text-2xl text-blue-500"></i>
                </div>
                <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900">Phiên bản ứng dụng</div>
                    <div class="text-sm text-gray-500">@Model.SystemStatus.ApplicationVersion</div>
                    <div class="text-xs text-blue-600">Hoạt động: @Model.SystemStatus.Uptime.ToString(@"d\d\ h\h\ m\m")</div>
                </div>
            </div>

            <!-- System Resources -->
            <div class="flex items-center p-4 bg-gray-50 rounded-lg">
                <div class="flex-shrink-0">
                    <i class="fas fa-microchip text-2xl text-purple-500"></i>
                </div>
                <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900">Tài nguyên hệ thống</div>
                    <div class="text-sm text-gray-500">CPU: @Model.SystemStatus.CpuUsage.ToString("F1")%</div>
                    <div class="text-xs text-purple-600">RAM: @Model.SystemStatus.MemoryUsage.ToString("F1")%</div>
                </div>
            </div>

            <!-- Services Status -->
            <div class="flex items-center p-4 bg-gray-50 rounded-lg">
                <div class="flex-shrink-0">
                    <i class="fas fa-envelope text-2xl @(Model.SystemStatus.IsEmailServiceRunning ? "text-green-500" : "text-red-500")"></i>
                </div>
                <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900">Dịch vụ Email</div>
                    <div class="text-xs @(Model.SystemStatus.IsEmailServiceRunning ? "text-green-600" : "text-red-600")">
                        @(Model.SystemStatus.IsEmailServiceRunning ? "Hoạt động" : "Ngừng hoạt động")
                    </div>
                </div>
            </div>

            <!-- Notification Service -->
            <div class="flex items-center p-4 bg-gray-50 rounded-lg">
                <div class="flex-shrink-0">
                    <i class="fas fa-bell text-2xl @(Model.SystemStatus.IsNotificationServiceRunning ? "text-green-500" : "text-red-500")"></i>
                </div>
                <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900">Dịch vụ thông báo</div>
                    <div class="text-xs @(Model.SystemStatus.IsNotificationServiceRunning ? "text-green-600" : "text-red-600")">
                        @(Model.SystemStatus.IsNotificationServiceRunning ? "Hoạt động" : "Ngừng hoạt động")
                    </div>
                </div>
            </div>

            <!-- Backup Info -->
            <div class="flex items-center p-4 bg-gray-50 rounded-lg">
                <div class="flex-shrink-0">
                    <i class="fas fa-save text-2xl text-orange-500"></i>
                </div>
                <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900">Sao lưu gần nhất</div>
                    <div class="text-sm text-gray-500">@Model.SystemStatus.LastBackupDate.ToString("dd/MM/yyyy")</div>
                    <div class="text-xs text-orange-600">@Model.SystemStatus.LastBackupDate.ToString("HH:mm")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- System Actions -->
    <div class="bg-white p-6 rounded-lg shadow mb-8">
        <h3 class="text-xl font-semibold text-gray-900 mb-6">
            <i class="fas fa-tools mr-2 text-blue-600"></i>
            Thao tác hệ thống
        </h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <form method="post" asp-page-handler="BackupDatabase" class="inline">
                <button type="submit" class="w-full flex flex-col items-center p-4 bg-green-50 hover:bg-green-100 rounded-lg border border-green-200 transition-colors"
                        onclick="return confirm('Bạn có chắc chắn muốn sao lưu cơ sở dữ liệu?')">
                    <i class="fas fa-database text-2xl text-green-600 mb-2"></i>
                    <span class="text-sm font-medium text-gray-900">Sao lưu CSDL</span>
                    <span class="text-xs text-gray-500 text-center">Tạo bản sao lưu cơ sở dữ liệu</span>
                </button>
            </form>

            <form method="post" asp-page-handler="ClearCache" class="inline">
                <button type="submit" class="w-full flex flex-col items-center p-4 bg-blue-50 hover:bg-blue-100 rounded-lg border border-blue-200 transition-colors"
                        onclick="return confirm('Bạn có chắc chắn muốn xóa cache hệ thống?')">
                    <i class="fas fa-broom text-2xl text-blue-600 mb-2"></i>
                    <span class="text-sm font-medium text-gray-900">Xóa Cache</span>
                    <span class="text-xs text-gray-500 text-center">Làm sạch bộ nhớ đệm</span>
                </button>
            </form>

            <button type="button" class="w-full flex flex-col items-center p-4 bg-yellow-50 hover:bg-yellow-100 rounded-lg border border-yellow-200 transition-colors"
                    onclick="restartServices()">
                <i class="fas fa-redo text-2xl text-yellow-600 mb-2"></i>
                <span class="text-sm font-medium text-gray-900">Khởi động lại</span>
                <span class="text-xs text-gray-500 text-center">Khởi động lại dịch vụ</span>
            </button>

            <a asp-page="Reports" class="w-full flex flex-col items-center p-4 bg-purple-50 hover:bg-purple-100 rounded-lg border border-purple-200 transition-colors">
                <i class="fas fa-chart-line text-2xl text-purple-600 mb-2"></i>
                <span class="text-sm font-medium text-gray-900">Báo cáo</span>
                <span class="text-xs text-gray-500 text-center">Xem báo cáo hệ thống</span>
            </a>
        </div>
    </div>

    <!-- Application Settings -->
    <div class="bg-white p-6 rounded-lg shadow">
        <h3 class="text-xl font-semibold text-gray-900 mb-6">
            <i class="fas fa-cog mr-2 text-gray-600"></i>
            Cài đặt ứng dụng
        </h3>

        <form method="post" asp-page-handler="SaveSettings">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Application Name -->
                <div>
                    <label asp-for="Settings.ApplicationName" class="block text-sm font-medium text-gray-700 mb-2">
                        Tên ứng dụng <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Settings.ApplicationName" 
                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    <span asp-validation-for="Settings.ApplicationName" class="text-red-500 text-sm"></span>
                </div>

                <!-- Contact Email -->
                <div>
                    <label asp-for="Settings.ContactEmail" class="block text-sm font-medium text-gray-700 mb-2">
                        Email liên hệ <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Settings.ContactEmail" type="email"
                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    <span asp-validation-for="Settings.ContactEmail" class="text-red-500 text-sm"></span>
                </div>

                <!-- Contact Phone -->
                <div>
                    <label asp-for="Settings.ContactPhone" class="block text-sm font-medium text-gray-700 mb-2">
                        Số điện thoại liên hệ <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Settings.ContactPhone" type="tel"
                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    <span asp-validation-for="Settings.ContactPhone" class="text-red-500 text-sm"></span>
                </div>

                <!-- Time Zone -->
                <div>
                    <label asp-for="Settings.TimeZone" class="block text-sm font-medium text-gray-700 mb-2">
                        Múi giờ
                    </label>
                    <select asp-for="Settings.TimeZone" 
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="Asia/Ho_Chi_Minh">Việt Nam (GMT+7)</option>
                        <option value="UTC">UTC (GMT+0)</option>
                    </select>
                </div>

                <!-- Log Retention Days -->
                <div>
                    <label asp-for="Settings.LogRetentionDays" class="block text-sm font-medium text-gray-700 mb-2">
                        Thời gian lưu trữ log (ngày)
                    </label>
                    <input asp-for="Settings.LogRetentionDays" type="number" min="1" max="365"
                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    <span asp-validation-for="Settings.LogRetentionDays" class="text-red-500 text-sm"></span>
                </div>

                <!-- Default Page Size -->
                <div>
                    <label asp-for="Settings.DefaultPageSize" class="block text-sm font-medium text-gray-700 mb-2">
                        Kích thước trang mặc định
                    </label>
                    <select asp-for="Settings.DefaultPageSize" 
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="10">10 mục</option>
                        <option value="20">20 mục</option>
                        <option value="50">50 mục</option>
                        <option value="100">100 mục</option>
                    </select>
                </div>
            </div>

            <!-- Notification Settings -->
            <div class="mt-8">
                <h4 class="text-lg font-medium text-gray-900 mb-4">Cài đặt thông báo</h4>
                <div class="space-y-4">
                    <div class="flex items-center">
                        <input asp-for="Settings.EnableEmailNotifications" type="checkbox" 
                               class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" />
                        <label asp-for="Settings.EnableEmailNotifications" class="ml-2 text-sm text-gray-700">
                            Bật thông báo qua Email
                        </label>
                    </div>
                    <div class="flex items-center">
                        <input asp-for="Settings.EnableSmsNotifications" type="checkbox" 
                               class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" />
                        <label asp-for="Settings.EnableSmsNotifications" class="ml-2 text-sm text-gray-700">
                            Bật thông báo qua SMS
                        </label>
                    </div>
                </div>
            </div>

            <!-- Maintenance Mode -->
            <div class="mt-8">
                <h4 class="text-lg font-medium text-gray-900 mb-4">Chế độ bảo trì</h4>
                <div class="flex items-center p-4 bg-yellow-50 rounded-lg border border-yellow-200">
                    <input asp-for="Settings.EnableMaintenanceMode" type="checkbox" 
                           class="h-4 w-4 text-yellow-600 focus:ring-yellow-500 border-gray-300 rounded" />
                    <label asp-for="Settings.EnableMaintenanceMode" class="ml-2 text-sm text-gray-700">
                        Bật chế độ bảo trì
                    </label>
                    <p class="ml-4 text-xs text-yellow-700">
                        <i class="fas fa-exclamation-triangle mr-1"></i>
                        Khi bật, người dùng sẽ không thể truy cập hệ thống
                    </p>
                </div>
            </div>

            <!-- Save Button -->
            <div class="flex justify-end mt-8">
                <button type="submit" class="px-6 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600 transition-colors">
                    <i class="fas fa-save mr-2"></i>Lưu cài đặt
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Include FontAwesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<!-- Validation Scripts -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

<script>
    function restartServices() {
        if (confirm('Bạn có chắc chắn muốn khởi động lại các dịch vụ? Hệ thống có thể tạm thời ngừng hoạt động.')) {
            // In a real app, this would call an API endpoint
            alert('Tính năng này sẽ được triển khai trong phiên bản tiếp theo.');
        }
    }

    // Auto-refresh system status every 30 seconds
    setInterval(function() {
        // In a real app, this would fetch fresh status data
        console.log('Refreshing system status...');
    }, 30000);
</script>
