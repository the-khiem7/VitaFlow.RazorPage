@page "{id:guid}"
@model VitaFlow.Web.Pages.Donors.DetailsModel
@{
    ViewData["Title"] = "Chi tiết người hiến máu";
}

<div class="max-w-4xl mx-auto p-6">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-3xl font-bold text-blue-700">Chi tiết người hiến máu</h1>
            <nav class="text-sm text-gray-500 mt-2">
                <a asp-page="Index" class="hover:text-blue-600">Danh sách người hiến máu</a>
                <span class="mx-2">/</span>
                <span>@Model.Donor.FirstName @Model.Donor.LastName</span>
            </nav>
        </div>
        <div class="flex space-x-2">
            <a asp-page="History" asp-route-id="@Model.Donor.Id" 
               class="px-4 py-2 bg-green-500 text-white rounded hover:bg-green-600 transition-colors">
                <i class="fas fa-history mr-2"></i>Lịch sử hiến máu
            </a>
            <a asp-page="Index" class="px-4 py-2 bg-gray-500 text-white rounded hover:bg-gray-600 transition-colors">
                <i class="fas fa-arrow-left mr-2"></i>Quay lại
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Information -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Personal Information Card -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="px-6 py-4 bg-blue-50 border-b">
                    <h2 class="text-xl font-semibold text-blue-700">
                        <i class="fas fa-user mr-2"></i>Thông tin cá nhân
                    </h2>
                </div>
                <div class="p-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-1">Họ và tên</label>
                            <p class="text-lg font-semibold text-gray-900">@Model.Donor.FirstName @Model.Donor.LastName</p>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-1">Ngày sinh</label>
                            <p class="text-gray-900">@Model.Donor.DateOfBirth.ToString("dd/MM/yyyy")</p>
                            <p class="text-sm text-gray-500">(@Model.CalculateAge(Model.Donor.DateOfBirth) tuổi)</p>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-1">Email</label>
                            <p class="text-gray-900">
                                <a href="mailto:@Model.Donor.Email" class="text-blue-600 hover:underline">
                                    @Model.Donor.Email
                                </a>
                            </p>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-1">Số điện thoại</label>
                            <p class="text-gray-900">
                                <a href="tel:@Model.Donor.PhoneNumber" class="text-blue-600 hover:underline">
                                    @Model.Donor.PhoneNumber
                                </a>
                            </p>
                        </div>
                        
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-gray-600 mb-1">Địa chỉ</label>
                            <p class="text-gray-900">@Model.Donor.Address</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Medical Information Card -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="px-6 py-4 bg-red-50 border-b">
                    <h2 class="text-xl font-semibold text-red-700">
                        <i class="fas fa-heartbeat mr-2"></i>Thông tin y tế
                    </h2>
                </div>
                <div class="p-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-1">Nhóm máu</label>
                            <span class="inline-flex items-center px-4 py-2 rounded-full text-lg font-bold bg-red-100 text-red-800">
                                @Model.Donor.BloodType
                            </span>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-1">Lần hiến máu cuối</label>
                            @if (Model.Donor.LastDonationDate.HasValue)
                            {
                                <p class="text-gray-900">@Model.Donor.LastDonationDate.Value.ToString("dd/MM/yyyy")</p>
                                <p class="text-sm text-gray-500">
                                    (@Model.CalculateDaysSinceLastDonation(Model.Donor.LastDonationDate.Value) ngày trước)
                                </p>
                            }
                            else
                            {
                                <p class="text-gray-500">Chưa hiến lần nào</p>
                            }
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-1">Ngày có thể hiến tiếp theo</label>
                            @if (Model.Donor.NextAvailableDate.HasValue)
                            {
                                if (Model.Donor.NextAvailableDate <= DateTime.Now)
                                {
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                                        <i class="fas fa-check mr-1"></i>Có thể hiến máu ngay
                                    </span>
                                }
                                else
                                {
                                    <p class="text-gray-900">@Model.Donor.NextAvailableDate.Value.ToString("dd/MM/yyyy")</p>
                                    <p class="text-sm text-orange-600">
                                        (Còn @Model.CalculateDaysUntilAvailable(Model.Donor.NextAvailableDate.Value) ngày)
                                    </p>
                                }
                            }
                            else
                            {
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                                    <i class="fas fa-check mr-1"></i>Có thể hiến máu ngay
                                </span>
                            }
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-1">Tổng số lần hiến máu</label>
                            <p class="text-2xl font-bold text-blue-600">@Model.DonationCount</p>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(Model.Donor.MedicalNotes))
                        {
                            <div class="md:col-span-2">
                                <label class="block text-sm font-medium text-gray-600 mb-1">Ghi chú y tế</label>
                                <div class="bg-yellow-50 border border-yellow-200 rounded p-4">
                                    <p class="text-gray-900">@Model.Donor.MedicalNotes</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Recent Donations -->
            @if (Model.RecentDonations?.Any() == true)
            {
                <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                    <div class="px-6 py-4 bg-green-50 border-b">
                        <h2 class="text-xl font-semibold text-green-700">
                            <i class="fas fa-history mr-2"></i>Lịch sử hiến máu gần đây
                        </h2>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ngày hiến</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Thể tích (ml)</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Trạng thái</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ghi chú</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                @foreach (var donation in Model.RecentDonations.Take(5))
                                {
                                    <tr>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                            @donation.DonationDate.ToString("dd/MM/yyyy")
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                            @donation.Volume ml
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            @{
                                                var statusClass = donation.Status switch
                                                {
                                                    VitaFlow.Core.Enums.DonationStatus.Completed => "bg-green-100 text-green-800",
                                                    VitaFlow.Core.Enums.DonationStatus.Processing => "bg-yellow-100 text-yellow-800",
                                                    VitaFlow.Core.Enums.DonationStatus.Canceled => "bg-red-100 text-red-800",
                                                    _ => "bg-gray-100 text-gray-800"
                                                };
                                                var statusText = donation.Status switch
                                                {
                                                    VitaFlow.Core.Enums.DonationStatus.Completed => "Hoàn thành",
                                                    VitaFlow.Core.Enums.DonationStatus.Processing => "Đang xử lý",
                                                    VitaFlow.Core.Enums.DonationStatus.Canceled => "Đã hủy",
                                                    _ => donation.Status.ToString()
                                                };
                                            }
                                            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium @statusClass">
                                                @statusText
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-sm text-gray-900">
                                            @(string.IsNullOrEmpty(donation.Notes) ? "-" : donation.Notes)
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (Model.DonationCount > 5)
                    {
                        <div class="px-6 py-4 bg-gray-50 text-center">
                            <a asp-page="History" asp-route-id="@Model.Donor.Id" 
                               class="text-blue-600 hover:text-blue-800 font-medium">
                                Xem tất cả @Model.DonationCount lần hiến máu
                            </a>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Side Panel -->
        <div class="space-y-6">
            <!-- Status Card -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="px-6 py-4 bg-gray-50 border-b">
                    <h3 class="text-lg font-semibold text-gray-700">
                        <i class="fas fa-info-circle mr-2"></i>Trạng thái
                    </h3>
                </div>
                <div class="p-6 space-y-4">
                    <div class="flex items-center justify-between">
                        <span class="text-gray-600">Đang hoạt động</span>
                        @if (Model.Donor.IsActive)
                        {
                            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                <i class="fas fa-check mr-1"></i>Có
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                <i class="fas fa-times mr-1"></i>Không
                            </span>
                        }
                    </div>
                    
                    <div class="flex items-center justify-between">
                        <span class="text-gray-600">Sẵn sàng khẩn cấp</span>
                        @if (Model.Donor.IsEmergencyDonor)
                        {
                            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                <i class="fas fa-exclamation-triangle mr-1"></i>Có
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                <i class="fas fa-minus mr-1"></i>Không
                            </span>
                        }
                    </div>
                    
                    <div class="pt-4 border-t border-gray-200">
                        <div class="text-center">
                            @if (Model.CanDonateNow())
                            {
                                <div class="text-green-600 font-medium mb-2">
                                    <i class="fas fa-check-circle mr-2"></i>Có thể hiến máu ngay
                                </div>
                                <button class="w-full px-4 py-2 bg-green-500 text-white rounded hover:bg-green-600 transition-colors">
                                    Tạo yêu cầu hiến máu
                                </button>
                            }
                            else
                            {
                                <div class="text-orange-600 font-medium mb-2">
                                    <i class="fas fa-clock mr-2"></i>Chưa thể hiến máu
                                </div>
                                <p class="text-sm text-gray-500">
                                    Có thể hiến lại sau @Model.CalculateDaysUntilAvailable(Model.Donor.NextAvailableDate!.Value) ngày
                                </p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Blood Compatibility -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="px-6 py-4 bg-red-50 border-b">
                    <h3 class="text-lg font-semibold text-red-700">
                        <i class="fas fa-heart mr-2"></i>Tương thích nhóm máu
                    </h3>
                </div>
                <div class="p-6">
                    <div class="text-center mb-4">
                        <div class="text-3xl font-bold text-red-600 mb-2">@Model.Donor.BloodType</div>
                        <p class="text-sm text-gray-600">Nhóm máu của người hiến</p>
                    </div>
                    
                    <div>
                        <p class="text-sm font-medium text-gray-600 mb-2">Có thể hiến cho:</p>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var compatibleType in Model.GetCompatibleRecipientTypes(Model.Donor.BloodType))
                            {
                                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                    @compatibleType
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Stats -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="px-6 py-4 bg-blue-50 border-b">
                    <h3 class="text-lg font-semibold text-blue-700">
                        <i class="fas fa-chart-bar mr-2"></i>Thống kê nhanh
                    </h3>
                </div>
                <div class="p-6 space-y-4">
                    <div class="flex justify-between items-center">
                        <span class="text-gray-600">Tổng lần hiến máu</span>
                        <span class="text-xl font-bold text-blue-600">@Model.DonationCount</span>
                    </div>
                    
                    <div class="flex justify-between items-center">
                        <span class="text-gray-600">Tổng thể tích (ml)</span>
                        <span class="text-xl font-bold text-red-600">@Model.TotalVolumeML</span>
                    </div>
                    
                    @if (Model.Donor.LastDonationDate.HasValue)
                    {
                        <div class="flex justify-between items-center">
                            <span class="text-gray-600">Ngày gần nhất</span>
                            <span class="text-sm text-gray-900">@Model.Donor.LastDonationDate.Value.ToString("dd/MM/yyyy")</span>
                        </div>
                    }
                    
                    <div class="pt-4 border-t border-gray-200 text-center">
                        <p class="text-sm text-gray-500">
                            Thành viên từ @(Model.Donor.CreatedAt.Year > 1900 ? Model.Donor.CreatedAt.ToString("MM/yyyy") : "N/A")
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
