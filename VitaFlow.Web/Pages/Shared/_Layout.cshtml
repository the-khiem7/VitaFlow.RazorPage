<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VitaFlow.Web</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VitaFlow.Web.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <!-- Đã loại bỏ Bootstrap, chỉ dùng TailwindCSS -->
    <style>
        html, body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="min-h-screen flex flex-col bg-gradient-to-br from-pink-50 via-blue-50 to-white">
    <header class="bg-white/80 shadow-lg sticky top-0 z-30 backdrop-blur">
        <nav class="container mx-auto flex items-center justify-between py-4 px-4">
            <a class="flex items-center space-x-2 text-3xl font-extrabold text-pink-600 tracking-wide drop-shadow-lg" asp-area="" asp-page="/Index">
                <span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-pink-500 animate-pulse" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2C10 2 4 9.5 4 13a6 6 0 0012 0c0-3.5-6-11-6-11z" /></svg>
                </span>
                <span>VitaFlow.Web</span>
            </a>
            <ul class="hidden md:flex space-x-8 bg-gradient-to-r from-pink-400 via-blue-400 to-pink-400 bg-clip-text text-transparent font-semibold text-lg">
                <li>
                    <a class="px-3 py-1 rounded transition-all duration-200 hover:bg-pink-100 hover:text-pink-700 hover:underline underline-offset-8 decoration-2 shadow-sm" asp-area="" asp-page="/Index">Trang chủ</a>
                </li>
                <li>
                    <a class="px-3 py-1 rounded transition-all duration-200 hover:bg-blue-100 hover:text-blue-700 hover:underline underline-offset-8 decoration-2 shadow-sm" asp-area="" asp-page="/Donors/Register">Đăng ký hiến máu</a>
                </li>
                <li>
                    <a class="px-3 py-1 rounded transition-all duration-200 hover:bg-red-100 hover:text-red-700 hover:underline underline-offset-8 decoration-2 shadow-sm" asp-area="" asp-page="/BloodRequests/Create">Tra cứu</a>
                </li>
                <li>
                    <a class="px-3 py-1 rounded transition-all duration-200 hover:bg-blue-50 hover:text-blue-700 hover:underline underline-offset-8 decoration-2 shadow-sm" asp-area="" asp-page="/Account/Login">Đăng nhập</a>
                </li>
                <li>
                    <a class="px-3 py-1 rounded transition-all duration-200 hover:bg-gray-100 hover:text-gray-700 hover:underline underline-offset-8 decoration-2 shadow-sm" asp-area="" asp-page="/Account/Logout">Đăng xuất</a>
                </li>
            </ul>
            <!-- Mobile menu button -->
            <div class="md:hidden flex items-center">
                <button id="mobile-menu-btn" class="text-pink-600 focus:outline-none focus:ring-2 focus:ring-pink-400 p-2 rounded">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
                </button>
            </div>
        </nav>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="md:hidden hidden px-4 pb-4">
            <ul class="flex flex-col space-y-2 bg-white/90 rounded-xl shadow-lg p-4 mt-2">
                <li>
                    <a class="block px-3 py-2 rounded transition-all duration-200 hover:bg-pink-100 hover:text-pink-700 font-semibold" asp-area="" asp-page="/Index">Home</a>
                </li>
                <li>
                    <a class="block px-3 py-2 rounded transition-all duration-200 hover:bg-blue-100 hover:text-blue-700 font-semibold" asp-area="" asp-page="/Privacy">Privacy</a>
                </li>
            </ul>
        </div>
        <script>
            // Simple mobile menu toggle
            document.addEventListener('DOMContentLoaded', function() {
                const btn = document.getElementById('mobile-menu-btn');
                const menu = document.getElementById('mobile-menu');
                btn.addEventListener('click', () => {
                    menu.classList.toggle('hidden');
                });
            });
        </script>
    </header>
    <main class="flex-1 flex flex-col items-center justify-center container mx-auto px-4 py-12">
        @RenderBody()
    </main>
    <footer class="bg-white/80 border-t py-6 mt-8 shadow-inner">
        <div class="container mx-auto text-center text-gray-500 text-base tracking-wide">
            &copy; 2025 - <span class="font-bold text-pink-600">VitaFlow.Web</span> | Liên hệ: <a href="mailto:info@vitaflow.vn" class="text-blue-500 hover:underline">info@vitaflow.vn</a> | SĐT: 0123 456 789<br/>
            Kết nối: <a href="#" class="text-blue-400 hover:underline mx-1">Facebook</a> <a href="#" class="text-pink-400 hover:underline mx-1">Instagram</a> <a href="#" class="text-blue-600 hover:underline mx-1">Zalo</a>
        </div>
    </footer>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>