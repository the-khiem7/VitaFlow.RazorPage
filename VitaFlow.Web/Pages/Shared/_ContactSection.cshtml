@{
    var sent = Context.Request.Query["sent"] == "1";
}
<section class="w-full py-8 md:py-12 flex flex-col items-center mb-8 animate-fade-in-up">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-2xl p-6 border-2 border-pink-200">
        <div class="flex justify-center mb-2">
            <svg class="w-10 h-10 text-pink-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2C10 2 4 9.5 4 13a6 6 0 0012 0c0-3.5-6-11-6-11z" /></svg>
        </div>
        <h3 class="text-2xl font-bold text-blue-700 text-center mb-4">Liên hệ / Đăng ký nhận tư vấn</h3>
        @if (sent) {
            <div class="bg-green-100 text-green-700 rounded p-3 text-center mb-4 shadow">Gửi liên hệ thành công! Chúng tôi sẽ phản hồi sớm nhất.</div>
        } else {
            <form method="get" class="space-y-4">
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Họ và tên</label>
                    <input type="text" name="name" required class="w-full px-3 py-2 border border-blue-200 rounded focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Email</label>
                    <input type="email" name="email" required class="w-full px-3 py-2 border border-blue-200 rounded focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Nội dung</label>
                    <textarea name="message" rows="3" required class="w-full px-3 py-2 border border-blue-200 rounded focus:outline-none focus:ring-2 focus:ring-blue-400"></textarea>
                </div>
                <button type="submit" name="sent" value="1" class="w-full py-2 bg-pink-500 text-white rounded font-semibold hover:bg-pink-600 transition">Gửi liên hệ</button>
            </form>
        }
    </div>
</section> 